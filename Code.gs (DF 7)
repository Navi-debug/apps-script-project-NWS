const SECONDARY_WORKBOOK_ID = ''; 
const ZAR49_WORKBOOK_ID = '1RwFe3as4vlCXc0oMRdntzGVufgXSDInIJwPy6L_pwuw'; 
const CACHE_SHEET_NAME = '_NWS_CACHE_';

function doGet() {
  return HtmlService.createTemplateFromFile('Index')
    .evaluate()
    .setTitle('Move, Train & Run | NWS')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function getDashboardData() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const cacheSheet = ss.getSheetByName(CACHE_SHEET_NAME);
  
  if (!cacheSheet || cacheSheet.getLastRow() === 0) {
    return updateCache(); 
  }
  
  const dataChunks = cacheSheet.getDataRange().getValues();
  const jsonString = dataChunks.map(row => row[0]).join('');
  return jsonString; 
}

function updateCache() {
  const finalData = calculateDashboardData(); 
  const jsonString = JSON.stringify(finalData); 
  
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let cacheSheet = ss.getSheetByName(CACHE_SHEET_NAME);
  if (!cacheSheet) {
    cacheSheet = ss.insertSheet(CACHE_SHEET_NAME);
    cacheSheet.hideSheet(); 
  }
  
  const chunks = jsonString.match(/[\s\S]{1,45000}/g);
  const rows = chunks.map(chunk => [chunk]);
  
  cacheSheet.clear();
  cacheSheet.getRange(1, 1, rows.length, 1).setValues(rows);
  
  return jsonString; 
}

function forceSyncData() {
  return updateCache();
}

function calculateDashboardData() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const secondarySS = SECONDARY_WORKBOOK_ID ? SpreadsheetApp.openById(SECONDARY_WORKBOOK_ID) : ss;

  const models = {}; 
  const perfModels = {};
  let activeModelsCount = 0;
  const secondLifeRegex = /2nd\s*life/i; 

  const lsSheet = ss.getSheetByName('LS1,2 Models');
  if (lsSheet) {
    const lsData = lsSheet.getDataRange().getValues();
    const codeRegex = /^\d{7}$/; 

    for (let i = 2; i < lsData.length; i++) { 
      let val1 = String(lsData[i][12]).trim(); 
      let mName1 = String(lsData[i][13] || '').trim();
      
      if (codeRegex.test(val1) && !models[val1] && !secondLifeRegex.test(mName1)) {
        models[val1] = { 
          isNew: false, code: val1, mName: mName1, 
          prod1: String(lsData[i][8] || '').trim(), prod2: String(lsData[i][9] || '').trim(),
          nop: String(lsData[i][9] || '').trim(), sector: String(lsData[i][2] || '').trim(), 
          dept: String(lsData[i][3] || '').trim(), subdept: String(lsData[i][2] || '').trim(), 
          family: String(lsData[i][7] || '').trim(), dsm: String(lsData[i][11] || '').trim(), codeAbc: String(lsData[i][6] || '').trim(),
          isQcTarget: false, myntraStatus: '', ajioStatus: '', tataCliqStatus: '', blinkit: '', zepto: '', swiggy: '', cataloguePrice: '', mpPrice: ''
        };
        activeModelsCount++;
      }
      
      let newCode = null;
      for (let c = 18; c < lsData[i].length; c++) {
        let testVal = String(lsData[i][c]).trim();
        if (codeRegex.test(testVal)) { newCode = testVal; break; }
      }

      if (newCode && !models[newCode]) {
        let mName2 = String(lsData[i][28] || '').trim();
        if (!secondLifeRegex.test(mName2)) {
          models[newCode] = { 
            isNew: true, code: newCode, mName: mName2, 
            prod1: String(lsData[i][8+18] || '').trim(), prod2: String(lsData[i][9+18] || '').trim(),
            nop: String(lsData[i][9+18] || '').trim(), sector: String(lsData[i][19] || '').trim(), 
            dept: String(lsData[i][20] || '').trim(), subdept: String(lsData[i][19] || '').trim(), 
            family: String(lsData[i][23] || '').trim(), dsm: String(lsData[i][26] || '').trim(), codeAbc: String(lsData[i][22] || '').trim(),
            isQcTarget: false, myntraStatus: '', ajioStatus: '', tataCliqStatus: '', blinkit: '', zepto: '', swiggy: '', cataloguePrice: '', mpPrice: ''
          };
        }
      }
    }
  }

  try {
    const zarSS = SpreadsheetApp.openById(ZAR49_WORKBOOK_ID);
    const zarSheet = zarSS.getSheetByName('Main');
    if (zarSheet) {
      const zarData = zarSheet.getDataRange().getValues();
      let mCodeIdx = -1, priceIdx = -1;
      for(let r=0; r<5 && (mCodeIdx===-1 || priceIdx===-1); r++) {
        for(let c=0; c<zarData[r].length; c++) {
          let h = String(zarData[r][c]).trim().toLowerCase();
          if(h === 'model code' || h === 'model') mCodeIdx = c;
          if(h === 'sales prices' || h === 'sales price' || h === 'mrp') priceIdx = c;
        }
      }
      if(mCodeIdx !== -1 && priceIdx !== -1) {
        const priceMap = {};
        for(let i=0; i<zarData.length; i++) {
          let mCode = String(zarData[i][mCodeIdx]).trim();
          let price = zarData[i][priceIdx];
          if(!mCode || isNaN(price) || price === '') continue;
          if(!priceMap[mCode]) priceMap[mCode] = {};
          priceMap[mCode][price] = (priceMap[mCode][price] || 0) + 1;
        }
        for(let mCode in priceMap) {
          let maxCount = 0, mostRecurring = null;
          for(let p in priceMap[mCode]) {
            if(priceMap[mCode][p] > maxCount) { maxCount = priceMap[mCode][p]; mostRecurring = p; }
          }
          if(models[mCode]) models[mCode].cataloguePrice = mostRecurring;
        }
      }
    }
  } catch(e) { }

  const mpSheet = secondarySS.getSheetByName('MP Offer') || ss.getSheetByName('MP Offer');
  if (mpSheet) {
    const mpData = mpSheet.getDataRange().getValues();
    let head = mpData[0].map(h => String(h).trim().toLowerCase());
    let iMyn = head.findIndex(h => h.includes('myntra'));
    let iAji = head.findIndex(h => h.includes('ajio'));
    let iTat = head.findIndex(h => h.includes('tata'));
    let iMpP = head.findIndex(h => h.includes('mp price'));
    let iGen = head.findIndex(h => h.includes('gender'));

    for(let i=1; i<mpData.length; i++) {
      let mCode = String(mpData[i][0]).trim();
      if(models[mCode]) {
        if(iMpP > -1) models[mCode].mpPrice = mpData[i][iMpP]; 
        if(iGen > -1) models[mCode].fallbackGender = String(mpData[i][iGen] || ''); 
        if(iMyn > -1) models[mCode].myntraStatus = String(mpData[i][iMyn] || '').trim();
        if(iAji > -1) models[mCode].ajioStatus = String(mpData[i][iAji] || '').trim();
        if(iTat > -1) models[mCode].tataCliqStatus = String(mpData[i][iTat] || '').trim();
      }
    }
  }

  const attrSheet = secondarySS.getSheetByName('Attribute Dump') || ss.getSheetByName('Attribute Dump');
  if (attrSheet) {
    const attrData = attrSheet.getDataRange().getValues();
    for(let i=1; i<attrData.length; i++) {
      let mCode = String(attrData[i][1]).trim(); 
      if(models[mCode]) {
        let primaryNop = String(attrData[i][6]).trim(); 
        if(primaryNop) models[mCode].nop = primaryNop; 
        models[mCode].gender = String(attrData[i][12] || ''); 
        models[mCode].sportpractice = String(attrData[i][13] || ''); 
        models[mCode].onlineSuggestedName = String(attrData[i][7] || ''); 
        let colorMatch = String(attrData[i][14] || '').match(/"bcdHexaLabel"\s*:\s*"([^"]+)"/i);
        models[mCode].color = colorMatch ? colorMatch[1] : ''; 
      }
    }
  }

  for (let key in models) {
    let g = models[key].gender || models[key].fallbackGender || '';
    if (g.toUpperCase().includes('MENS + UNISEX') || g.toUpperCase().includes('MENS+UNISEX')) g = 'No Gender';
    models[key].finalGender = g;
  }

  const qcSheet = ss.getSheetByName('QC Offer');
  if (qcSheet) {
    const qcData = qcSheet.getDataRange().getValues();
    let head = qcData[0].map(h => String(h).trim().toLowerCase());
    
    let iMod = head.findIndex(h => h === 'model code' || h === 'model' || h.includes('model'));
    if(iMod === -1) iMod = 0;

    let iZep = head.findIndex(h => h.includes('zepto'));
    let iSwi = head.findIndex(h => h.includes('swiggy'));
    let iBli = head.findIndex(h => h.includes('blinkit'));
    let permColIdx = head.findIndex(h => h.includes('permanent') || h.includes('considered'));
    
    if (permColIdx === -1) { permColIdx = qcData[0].length; qcSheet.getRange(1, permColIdx + 1).setValue('QC Target Permanent'); }
    
    for (let i = 1; i < qcData.length; i++) {
      let mCode = String(qcData[i][iMod]).trim();
      if (models[mCode]) {
        if(iZep > -1) models[mCode].zepto = String(qcData[i][iZep] || '').trim().toUpperCase();
        if(iSwi > -1) models[mCode].swiggy = String(qcData[i][iSwi] || '').trim().toUpperCase();
        if(iBli > -1) models[mCode].blinkit = String(qcData[i][iBli] || '').trim().toUpperCase();
        let isChecked = qcData[i][permColIdx];
        models[mCode].isQcTarget = (isChecked === true || String(isChecked).toUpperCase() === 'TRUE');
      }
    }
  }

  const qcSalesSheet = ss.getSheetByName('QC Sales (Sell in - Sales)');
  const qcWeekly = {}; 
  if (qcSalesSheet) {
    const qcsData = qcSalesSheet.getDataRange().getValues();
    const qcsHeaders = qcsData[0];
    let mIdx = qcsHeaders.indexOf('Model');
    let dIdx = qcsHeaders.indexOf('Invoice date');
    let vIdx = qcsHeaders.indexOf('Total');
    let qIdx = -1;
    for(let i=0; i<qcsHeaders.length; i++) { if(String(qcsHeaders[i]).toLowerCase().includes('shipped')) { qIdx = i; break; } }

    if(mIdx > -1 && dIdx > -1) {
      for(let i=1; i<qcsData.length; i++) {
        let mCode = String(qcsData[i][mIdx]).trim();
        let dateObj = parseCustomDate(qcsData[i][dIdx]);
        if(!dateObj || isNaN(dateObj)) continue;
        
        let rawQty = Number(String(qcsData[i][qIdx]).replace(/,/g, '')) || 0;
        let rawVal = Number(String(qcsData[i][vIdx]).replace(/,/g, '')) || 0;

        let yw = getISOWeekAndYear(dateObj);
        if(!qcWeekly[mCode]) qcWeekly[mCode] = {};
        if(!qcWeekly[mCode][yw.year]) qcWeekly[mCode][yw.year] = {};
        if(!qcWeekly[mCode][yw.year][yw.week]) qcWeekly[mCode][yw.year][yw.week] = { qty: 0, val: 0 };
        
        qcWeekly[mCode][yw.year][yw.week].qty += rawQty;
        qcWeekly[mCode][yw.year][yw.week].val += rawVal;
      }
    }
  }

  const mainSalesSheet = ss.getSheetByName('B2B + QC + MKPL Sales');
  if (mainSalesSheet) {
    const msData = mainSalesSheet.getDataRange().getValues();
    let rChan = -1, rYear = -1, rMonth = -1, rWeek = -1;
    for (let r = 0; r < 10 && r < msData.length; r++) {
      let rowStr = msData[r].join(' ').toLowerCase();
      if (rowStr.includes('distribution channel')) rChan = r;
      if (rowStr.includes('calendar year') && !rowStr.includes('year/w')) rYear = r;
      if (rowStr.includes('calendar month')) rMonth = r;
      if (rowStr.includes('calendar year/w')) rWeek = r;
    }

    if (rChan !== -1 && rWeek !== -1) {
      let dataStartCol = -1;
      for (let c = 0; c < msData[rWeek].length; c++) {
        if (/^\d{1,2}\.\d{4}$/.test(String(msData[rWeek][c]).trim())) { dataStartCol = c; break; }
      }

      let codeCol = 8, nameCol = 9, keyFigCol = 11; 
      let firstDataRow = msData[rWeek + 1];
      if (firstDataRow) {
         for (let c = 0; c < dataStartCol; c++) {
           let val = String(firstDataRow[c]).trim();
           if (/^\d{7}$/.test(val)) codeCol = c;
           else if (val.includes('Sales Value') || val.includes('Sales Quantity')) keyFigCol = c;
         }
         nameCol = codeCol + 1; 
      }

      let colsMeta = [];
      let maxWeek26 = 0;
      let curChan = '', curYear = '', curMonth = '';

      for (let c = dataStartCol; c < msData[rWeek].length; c++) {
        if (msData[rChan][c]) curChan = String(msData[rChan][c]).trim();
        if (msData[rYear][c]) curYear = String(msData[rYear][c]).trim();
        if (msData[rMonth][c]) curMonth = String(msData[rMonth][c]).trim();

        let weekRaw = String(msData[rWeek][c]).trim();
        if (!weekRaw) continue;

        let w = parseInt(weekRaw.split('.')[0], 10);
        let y = parseInt(curYear, 10);
        let m = parseInt(curMonth, 10);

        if (y === 2026 && w > maxWeek26) maxWeek26 = w;
        colsMeta[c] = { channel: curChan, year: y, month: m, week: w };
      }

      const getBase = () => ({ mkpl26:0, mkpl25:0, qc26:0, qc25:0, b2b26:0, b2b25:0 });

      for (let r = rWeek + 1; r < msData.length; r++) {
        let row = msData[r];
        let mCode = String(row[codeCol]).trim();
        let mName = String(row[nameCol]).trim();
        let keyFig = String(row[keyFigCol]).trim();

        if (!mCode || secondLifeRegex.test(mName) || keyFig.includes('Margin')) continue;

        if (!perfModels[mCode]) {
          perfModels[mCode] = { 
            code: mCode, name: mName,
            sector: models[mCode] ? models[mCode].sector : '', dept: models[mCode] ? models[mCode].dept : '',
            subdept: models[mCode] ? models[mCode].subdept : '', family: models[mCode] ? models[mCode].family : '',
            prod2: models[mCode] ? models[mCode].prod2 : '', codeAbc: models[mCode] ? models[mCode].codeAbc : '',
            dsm: models[mCode] ? models[mCode].dsm : '',
            ytd: { val: getBase(), qty: getBase() }, fy25: { val: getBase(), qty: getBase() },
            months: {}, weeks: {}
          };
        }

        let metric = keyFig.includes('Quantity') ? 'qty' : 'val';
        let rowQcApplied = {}; 

        for (let c = dataStartCol; c < row.length; c++) {
          let meta = colsMeta[c];
          if (!meta) continue;

          let val = Number(String(row[c]).replace(/,/g, '')) || 0;
          if (val === 0 && metric !== 'qty') continue; 

          let yrKey = meta.year === 2026 ? '26' : (meta.year === 2025 ? '25' : null);
          if (!yrKey) continue;

          let isMkpl = meta.channel.toLowerCase().includes('marketplace');
          let isOthers = meta.channel.toLowerCase().includes('sales with others');

          let mkplVal = isMkpl ? val : 0;
          let b2bVal = 0, qcVal = 0;

          if (isOthers) {
             let qcKey = meta.year + '_' + meta.week;
             if (!rowQcApplied[qcKey]) {
                if (qcWeekly[mCode] && qcWeekly[mCode][meta.year] && qcWeekly[mCode][meta.year][meta.week]) {
                   qcVal = (metric === 'val') ? qcWeekly[mCode][meta.year][meta.week].val : qcWeekly[mCode][meta.year][meta.week].qty;
                }
                rowQcApplied[qcKey] = true; 
             }
             if (qcVal > val) qcVal = val; 
             b2bVal = val - qcVal;
          }

          let mObj = perfModels[mCode];
          if (meta.week <= maxWeek26) {
             if (isMkpl) mObj.ytd[metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.ytd[metric]['qc'+yrKey] += qcVal; mObj.ytd[metric]['b2b'+yrKey] += b2bVal; }
          }
          if (yrKey === '25') {
             if (isMkpl) mObj.fy25[metric].mkpl25 += mkplVal;
             if (isOthers) { mObj.fy25[metric].qc25 += qcVal; mObj.fy25[metric].b2b25 += b2bVal; }
          }
          if (meta.month >= 1 && meta.month <= 12) {
             if(!mObj.months[meta.month]) mObj.months[meta.month] = { val: getBase(), qty: getBase() };
             if (isMkpl) mObj.months[meta.month][metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.months[meta.month][metric]['qc'+yrKey] += qcVal; mObj.months[meta.month][metric]['b2b'+yrKey] += b2bVal; }
          }
          if (meta.week >= 1 && meta.week <= 52) {
             if(!mObj.weeks[meta.week]) mObj.weeks[meta.week] = { val: getBase(), qty: getBase() };
             if (isMkpl) mObj.weeks[meta.week][metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.weeks[meta.week][metric]['qc'+yrKey] += qcVal; mObj.weeks[meta.week][metric]['b2b'+yrKey] += b2bVal; }
          }
        }
      }
    }
  }

  for (let key in models) {
    if (secondLifeRegex.test(models[key].mName)) delete models[key];
  }

  const masterArray = Object.keys(models).map(k => models[k]);
  const perfArray = Object.keys(perfModels).map(k => perfModels[k]);

  return { masterData: masterArray, performanceData: perfArray, totalTracked: masterArray.length, timestamp: new Date().toLocaleString() };
}

function parseCustomDate(str) {
  if (!str) return null;
  if (str instanceof Date) return str;
  str = String(str).trim();
  let parts = str.split(/[-/]/);
  if (parts.length === 3) {
    let d = parseInt(parts[0], 10);
    let mStr = parts[1].toLowerCase();
    let y = parseInt(parts[2], 10);
    const monthNames = {jan:0, feb:1, mar:2, apr:3, may:4, jun:5, jul:6, aug:7, sep:8, oct:9, nov:10, dec:11};
    let m = isNaN(mStr) ? monthNames[mStr.substring(0,3)] : parseInt(mStr, 10) - 1;
    if (y < 100) y += 2000;
    let dt = new Date(y, m, d);
    if (!isNaN(dt.getTime())) return dt;
  }
  return new Date(str); 
}

function getISOWeekAndYear(date) {
  const d = new Date(date.getTime());
  d.setHours(0,0,0,0);
  d.setDate(d.getDate() + 4 - (d.getDay() || 7));
  const yearStart = new Date(d.getFullYear(),0,1);
  return { year: d.getFullYear(), week: Math.ceil((((d - yearStart) / 86400000) + 1)/7) };
}

// 🛡️ BULLETPROOF QC CHECKBOX SAVER
function toggleQcTargetInSheet(modelCode, isChecked) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const qcSheet = ss.getSheetByName('QC Offer');
    if(!qcSheet) return "No Sheet";
    
    const data = qcSheet.getDataRange().getValues();
    if(data.length === 0) return "Empty Sheet";
    
    let head = data[0].map(h => String(h).toLowerCase().trim());
    let iMod = head.findIndex(h => h === 'model code' || h === 'model' || h.includes('model'));
    if(iMod === -1) iMod = 0; // Absolute fallback

    let targetColIdx = head.findIndex(h => h.includes('permanent') || h.includes('considered'));
    
    // If the column somehow got deleted, recreate it so it never fails
    if(targetColIdx === -1) {
      targetColIdx = data[0].length;
      qcSheet.getRange(1, targetColIdx + 1).setValue('QC Target Permanent');
    }

    let found = false;
    for(let i=1; i<data.length; i++) {
      if(String(data[i][iMod]).trim() === String(modelCode).trim()) {
        qcSheet.getRange(i+1, targetColIdx + 1).setValue(isChecked);
        found = true;
        break;
      }
    }
    
    // If model isn't in QC sheet at all, actively ADD it to the bottom to ensure save
    if(!found) {
       let newRow = new Array(data[0].length).fill('');
       newRow[iMod] = modelCode;
       newRow[targetColIdx] = isChecked;
       qcSheet.appendRow(newRow);
    }
    
    // Silently update cache so future loads have the checked box
    updateCache(); 
    return "Success";
  } catch(e) {
    return "Error: " + e.message;
  }
}

function createExportSheet(data, title) {
  const ss = SpreadsheetApp.create("Export - " + title + " - " + new Date().toLocaleDateString());
  const sheet = ss.getSheets()[0];
  if(data && data.length > 0) {
    sheet.getRange(1, 1, data.length, data[0].length).setValues(data);
    sheet.getRange(1, 1, 1, data[0].length).setFontWeight("bold").setBackground("#e2e8f0");
  }
  return ss.getUrl();
}
