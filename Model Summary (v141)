    function renderTable() {
      const startWk = parseInt(document.getElementById('f-start').value);
      const endWk = parseInt(document.getElementById('f-end').value);
      const groupBy = document.getElementById('ctrl-group').value;
      
      const metric = document.getElementById('ctrl-metric').value;
      const agg = document.getElementById('ctrl-agg').value;
      const limitMode = document.getElementById('ctrl-limit-mode').value;
      const limitN = parseInt(document.getElementById('ctrl-limit-n').value) || 10;
      
      const thead = document.getElementById('bot-head');
      const tbody = document.getElementById('bot-body');

      if(filteredData.length === 0) {
        thead.innerHTML = ''; tbody.innerHTML = `<tr><td class="loading-msg" colspan="17">No data matches these filters.</td></tr>`; 
        generateInsights([], null, metric, endWk, null);
        return;
      }

      // SAFELY BOUND EVALUATION CALLBACK 
      function calcValue(dataObj, isMicroLevel) {
        if(metric === 'm') return dataObj.v === 0 ? 0 : (dataObj.m / dataObj.v) * 100;
        if(metric === 'p') return isMicroLevel ? dataObj.pwps_q : dataObj.pwps_v; 
        
        let raw = metric === 'q' ? dataObj.q : dataObj.v;
        if (agg === 'avg') {
            let implant = dataObj.minWk === 99 ? startWk : dataObj.minWk;
            let den = endWk - Math.max(startWk, implant) + 1;
            return den <= 0 ? 0 : (raw / den);
        }
        return raw;
      }
      
      function getSortValue(dataObj, isMicroLevel) {
        if(metric === 'm') return dataObj.m; 
        if(metric === 'p') return isMicroLevel ? dataObj.pwps_q : dataObj.pwps_v;
        
        let raw = metric === 'q' ? dataObj.q : dataObj.v;
        if (agg === 'avg') {
            let implant = dataObj.minWk === 99 ? startWk : dataObj.minWk;
            let den = endWk - Math.max(startWk, implant) + 1;
            return den <= 0 ? 0 : (raw / den);
        }
        return raw;
      }

      const createEmptyAgg = () => ({v:0, q:0, m:0, pwps_v:0, pwps_q:0, minWk:99, shtg_sum:0, shtg_cnt:0});

      let grandTotal = { OVERALL: { y: createEmptyAgg(), y1: createEmptyAgg(), y2: createEmptyAgg(), y3: createEmptyAgg() } };
      let grandTotalItemsSet = new Set();
      targetChannels.forEach(ch => grandTotal[ch.toUpperCase()] = { y: createEmptyAgg(), y1: createEmptyAgg(), y2: createEmptyAgg(), y3: createEmptyAgg() });

      let flatRowsToRender = [];
      let totalActiveModels = new Set();
      
      // FULL DEPTH PATH GENERATOR (ADDED ITEM LEVEL)
      let getPathConfig = function(r) {
          let mCode = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[1].trim().toUpperCase() : String(r.mod || '').trim().toUpperCase();
          let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm || '').trim().toUpperCase();
          if(!iCode) iCode = mCode || 'UNK';
          
          let safeSPT = String(r.spt || 'UNASSIGNED');
          let safeDEP = String(r.dep || 'UNASSIGNED');
          let safeSDEP = String(r.sdep || 'UNASSIGNED');
          let safeFAM = String(r.fam || 'UNASSIGNED');
          let safeTYP = String(r.typ || 'UNASSIGNED');
          let safeDSM = String(r.dsm || 'UNASSIGNED');
          let safeMOD = String(r.mod || 'UNASSIGNED');
          let safeITM = String(r.itm || 'UNASSIGNED');
          let safeNOP = String(r.nop || 'UNASSIGNED');
          let safeABC = String(r.abc || 'UNASSIGNED');
          let safeRNG = String(r.trueRng || r.rng || 'UNASSIGNED');

          return {
              'tree': [{v: safeSPT, t: 'spt'}, {v: safeDEP, t: 'dep'}, {v: safeSDEP, t: 'sdep'}, {v: safeFAM, t: 'fam'}, {v: safeTYP, t: 'typ'}, {v: safeDSM, t: 'dsm'}, {v: safeMOD, t: 'mod'}, {v: safeITM, t: 'itm', code: iCode}],
              'sdep': [{v: safeSDEP, t: 'sdep'}, {v: safeFAM, t: 'fam'}],
              'fam':  [{v: safeFAM, t: 'fam'}, {v: safeDSM, t: 'dsm'}],
              'typ':  [{v: safeTYP, t: 'typ'}, {v: safeDSM, t: 'dsm'}, {v: safeMOD, t: 'mod'}],
              'dsm':  [{v: safeDSM, t: 'dsm'}, {v: safeMOD, t: 'mod'}],
              'mod':  [{v: safeMOD, t: 'mod'}, {v: safeITM, t: 'itm', code: iCode}],
              'spt':  [{v: safeSPT, t: 'spt'}],
              'dep':  [{v: safeDEP, t: 'dep'}],
              'nop':  [{v: safeNOP, t: 'nop'}],
              'abc':  [{v: safeABC, t: 'abc'}],
              'rng':  [{v: safeRNG, t: 'rng'}]
          };
      };

      let tree = { id: 'root', children: {} };

      filteredData.forEach(r => {
          let mCode = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[1].trim().toUpperCase() : String(r.mod || '').trim().toUpperCase();
          let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm || '').trim().toUpperCase();
          if(!iCode) iCode = mCode || 'UNK';
          
          let rCh = String(r.ch).trim().toUpperCase();
          if (activeForecastModels.has(mCode) && mCode) totalActiveModels.add(mCode);

          let rowAgg = r.preAgg; 
          
          let safeGroupBy = String(r[groupBy] || 'UNASSIGNED');
          let pathData = getPathConfig(r)[groupBy] || [{v: safeGroupBy, t: 'unk'}];
          let curr = tree;
          
          pathData.forEach((step, idx) => {
              let p = String(step.v || 'UNASSIGNED');
              let nodeKey = p.replace(/\|/g, ''); 
              if (!curr.children[nodeKey]) {
                  let initChans = {};
                  ['OVERALL', ...targetChannels].forEach(c => {
                      initChans[String(c).trim().toUpperCase()] = { y: createEmptyAgg(), y1: createEmptyAgg(), y2: createEmptyAgg(), y3: createEmptyAgg() };
                  });
                  curr.children[nodeKey] = { id: curr.id + '|' + nodeKey, name: p, level: idx, type: step.t, code: step.code, activeModels: new Set(), itemsSet: new Set(), chans: initChans, children: {} };
              }
              curr = curr.children[nodeKey];
              if(activeForecastModels.has(mCode) && mCode) curr.activeModels.add(mCode);
              curr.itemsSet.add(iCode); 

              ['OVERALL', rCh].forEach(c => {
                  let chKey = String(c).trim().toUpperCase();
                  if (curr.chans[chKey]) {
                      let tg = curr.chans[chKey];
                      tg.y.v += rowAgg.y.v; tg.y.q += rowAgg.y.q; tg.y.m += rowAgg.y.m; tg.y.minWk = Math.min(tg.y.minWk, rowAgg.y.minWk); tg.y.shtg_sum += rowAgg.y.shtg_sum; tg.y.shtg_cnt += rowAgg.y.shtg_cnt;
                      tg.y1.v += rowAgg.y1.v; tg.y1.q += rowAgg.y1.q; tg.y1.m += rowAgg.y1.m; tg.y1.minWk = Math.min(tg.y1.minWk, rowAgg.y1.minWk); tg.y1.shtg_sum += rowAgg.y1.shtg_sum; tg.y1.shtg_cnt += rowAgg.y1.shtg_cnt;
                      tg.y2.v += rowAgg.y2.v; tg.y2.q += rowAgg.y2.q; tg.y2.m += rowAgg.y2.m; tg.y2.minWk = Math.min(tg.y2.minWk, rowAgg.y2.minWk); tg.y2.shtg_sum += rowAgg.y2.shtg_sum; tg.y2.shtg_cnt += rowAgg.y2.shtg_cnt;
                      tg.y3.v += rowAgg.y3.v; tg.y3.q += rowAgg.y3.q; tg.y3.m += rowAgg.y3.m; tg.y3.minWk = Math.min(tg.y3.minWk, rowAgg.y3.minWk); tg.y3.shtg_sum += rowAgg.y3.shtg_sum; tg.y3.shtg_cnt += rowAgg.y3.shtg_cnt;
                  }
              });
          });

          grandTotalItemsSet.add(iCode);
          ['OVERALL', rCh].forEach(c => {
              let chKey = String(c).trim().toUpperCase();
              if(grandTotal[chKey]) {
                  let tg = grandTotal[chKey];
                  tg.y.v += rowAgg.y.v; tg.y.q += rowAgg.y.q; tg.y.m += rowAgg.y.m; tg.y.minWk = Math.min(tg.y.minWk, rowAgg.y.minWk); tg.y.shtg_sum += rowAgg.y.shtg_sum; tg.y.shtg_cnt += rowAgg.y.shtg_cnt;
                  tg.y1.v += rowAgg.y1.v; tg.y1.q += rowAgg.y1.q; tg.y1.m += rowAgg.y1.m; tg.y1.minWk = Math.min(tg.y1.minWk, rowAgg.y1.minWk); tg.y1.shtg_sum += rowAgg.y1.shtg_sum; tg.y1.shtg_cnt += rowAgg.y1.shtg_cnt;
                  tg.y2.v += rowAgg.y2.v; tg.y2.q += rowAgg.y2.q; tg.y2.m += rowAgg.y2.m; tg.y2.minWk = Math.min(tg.y2.minWk, rowAgg.y2.minWk); tg.y2.shtg_sum += rowAgg.y2.shtg_sum; tg.y2.shtg_cnt += rowAgg.y2.shtg_cnt;
                  tg.y3.v += rowAgg.y3.v; tg.y3.q += rowAgg.y3.q; tg.y3.m += rowAgg.y3.m; tg.y3.minWk = Math.min(tg.y3.minWk, rowAgg.y3.minWk); tg.y3.shtg_sum += rowAgg.y3.shtg_sum; tg.y3.shtg_cnt += rowAgg.y3.shtg_cnt;
              }
          });
      });

      function applyPWPS(nodeMap, itemsSet) {
          ['OVERALL', ...targetChannels].forEach(c => {
              let chKey = String(c).trim().toUpperCase(); 
              if (nodeMap[chKey]) {
                  ['y', 'y1', 'y2', 'y3'].forEach(yKey => {
                      nodeMap[chKey][yKey].pwps_v = 0;
                      nodeMap[chKey][yKey].pwps_q = 0;
                      itemsSet.forEach(ic => {
                          if (globalItemPWPS[ic] && globalItemPWPS[ic][chKey] && globalItemPWPS[ic][chKey][yKey]) {
                              nodeMap[chKey][yKey].pwps_v += globalItemPWPS[ic][chKey][yKey].pwps_v;
                              nodeMap[chKey][yKey].pwps_q += globalItemPWPS[ic][chKey][yKey].pwps_q;
                          }
                      });
                  });
              }
          });
      }
      
      applyPWPS(grandTotal, grandTotalItemsSet);

      function flattenNode(node, list, parentVal) {
          let children = Object.values(node.children);
          if (children.length === 0) return;
          
          children.forEach(child => applyPWPS(child.chans, child.itemsSet));

          children.sort((a, b) => {
             let aMicro = (a.type === 'mod' || a.type === 'itm');
             let bMicro = (b.type === 'mod' || b.type === 'itm');
             
             if (sortCol === 'NAME') { 
                 let aName = String(a.name || '');
                 let bName = String(b.name || '');
                 return sortDir === 'asc' ? aName.localeCompare(bName) : bName.localeCompare(aName); 
             }
             let parts = sortCol.split('_'); let ch = parts[0], col = parts[1];
             let gA = a.chans[ch] || {y:createEmptyAgg(), y1:createEmptyAgg(), y2:createEmptyAgg(), y3:createEmptyAgg()};
             let gB = b.chans[ch] || {y:createEmptyAgg(), y1:createEmptyAgg(), y2:createEmptyAgg(), y3:createEmptyAgg()};
             
             let valA = 0, valB = 0;
             if(col === 'Y') { valA = getSortValue(gA.y, aMicro); valB = getSortValue(gB.y, bMicro); }
             else if(col === 'Y1') { valA = getSortValue(gA.y1, aMicro); valB = getSortValue(gB.y1, bMicro); }
             else if(col === 'Y2') { valA = getSortValue(gA.y2, aMicro); valB = getSortValue(gB.y2, bMicro); }
             
             if (valA === valB) return 0;
             return sortDir === 'asc' ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
          });

          if (limitMode !== 'all') { children = children.slice(0, limitN); }

          children.forEach(child => {
             child.isMicroLevel = (child.type === 'mod' || child.type === 'itm');
             if (metric === 'm') {
                 let childM = child.chans['OVERALL'].y.m;
                 child.pctCont = (parentVal && parentVal !== 0) ? ((childM / parentVal) * 100).toFixed(1) + '%' : "0.0%";
             } else if (metric !== 'p') {
                 let childVal = calcValue(child.chans['OVERALL'].y, child.isMicroLevel);
                 child.pctCont = (parentVal && parentVal !== 0) ? ((childVal / parentVal) * 100).toFixed(1) + '%' : "0.0%";
             } else { child.pctCont = ``; }

             list.push(child);
             if (expandedNodes.has(child.id)) {
                let passVal = metric === 'm' ? child.chans['OVERALL'].y.m : calcValue(child.chans['OVERALL'].y, child.isMicroLevel);
                flattenNode(child, list, passVal);
             }
          });
      }

      let rootVal = metric === 'm' ? grandTotal['OVERALL'].y.m : calcValue(grandTotal['OVERALL'].y, false);
      flattenNode(tree, flatRowsToRender, rootVal);
      
      // PASS CALCVALUE AS A SAFE CALLBACK TO PREVENT REFERENCE ERROR SCOPE CRASH
      generateInsights(flatRowsToRender, grandTotal['OVERALL'], metric, endWk, calcValue);

      let groupLabel = document.getElementById('ctrl-group').options[document.getElementById('ctrl-group').selectedIndex].text;
      let renderChans = ['OVERALL', ...targetChannels];
      
      let head1 = `<tr><th rowspan="2" class="sortable-header" onclick="setSort('NAME')">${groupLabel}${getSortIcon('NAME')}</th>`;
      let head2 = `<tr>`;
      renderChans.forEach(ch => {
        let chKey = String(ch).trim().toUpperCase();
        head1 += `<th colspan="3" class="col-divider">${chKey === 'OVERALL' ? 'OVERALL PORTFOLIO' : ch}</th>`;
        head2 += `<th class="sortable-header" onclick="setSort('${chKey}_Y')">${maxYear}${getSortIcon(`${chKey}_Y`)}</th>
                  <th class="sortable-header" onclick="setSort('${chKey}_Y1')">${maxYear-1}${getSortIcon(`${chKey}_Y1`)}</th>
                  <th class="col-divider sortable-header" onclick="setSort('${chKey}_Y2')">${maxYear-2}${getSortIcon(`${chKey}_Y2`)}</th>`;
      });
      head1 += `</tr>`; head2 += `</tr>`;
      thead.innerHTML = head1 + head2;

      function formatValue(num, isMicro) {
        if (metric === 'm') return num.toFixed(1) + '%';
        if (metric === 'p') {
            if (isMicro) return Number(num.toFixed(2)).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 2}) + ' u';
            return '₹' + Math.round(num).toLocaleString();
        }
        if (metric === 'q') return Math.round(num).toLocaleString() + ' u';
        return '₹' + Math.round(num).toLocaleString();
      }
      
      function renderYoYHTML(curr, prev, isPwpsStyle = false, isY2 = false) {
        if(prev === 0) {
            if (isY2 && isPwpsStyle) return ''; 
            return curr > 0 ? `<span style="color:#059669;">NEW</span>` : '';
        }
        let yoy = (((curr - prev) / prev) * 100);
        let clr = yoy >= 0 ? '#059669' : '#dc2626';
        if (isPwpsStyle) return `<span style="color:${clr};">(${yoy >= 0 ? '+' : ''}${yoy.toFixed(1)}%)</span>`;
        return `<span style="color:${clr};">${yoy >= 0 ? '+' : ''}${yoy.toFixed(1)}%</span>`;
      }
      
      function formatName(rawName) {
        let strName = String(rawName || '');
        if (!strName.includes('::')) return `<b>${strName}</b>`;
        let parts = strName.split('::');
        return `<b>${parts[0]}</b> <span style="color:#64748b; font-size:0.75rem;">[${parts[1]}]</span>`;
      }

      function getShtgColor(shtgPct) {
        let val = +(shtgPct * 100).toFixed(2);
        if (val <= 2.0) return '#059669'; 
        if (val <= 4.0) return '#d97706'; 
        return '#dc2626'; 
      }

      function buildRowHtml(dispName, dataMap, isMicro, isTotalRow = false) {
        let html = `<tr ${isTotalRow ? 'class="row-total"' : ''}><td><div style="display:flex; width:100%; box-sizing:border-box; align-items:center;">${dispName}</div></td>`;
        
        let getDenom = (minWk) => {
           let implant = minWk === 99 ? startWk : minWk;
           let den = endWk - Math.max(startWk, implant) + 1;
           return den <= 0 ? 0 : den;
        };

        renderChans.forEach(ch => {
          let matchCh = String(ch).trim().toUpperCase();
          let yObj = dataMap[matchCh] ? dataMap[matchCh].y : createEmptyAgg();
          let y1Obj = dataMap[matchCh] ? dataMap[matchCh].y1 : createEmptyAgg();
          let y2Obj = dataMap[matchCh] ? dataMap[matchCh].y2 : createEmptyAgg();
          let y3Obj = dataMap[matchCh] ? dataMap[matchCh].y3 : createEmptyAgg();

          let valY = calcValue(yObj, isMicro), valY1 = calcValue(y1Obj, isMicro), valY2 = calcValue(y2Obj, isMicro);
          
          let yoyValY = valY, yoyValY1 = valY1, yoyValY2 = valY2, yoyValY3 = calcValue(y3Obj, isMicro);
          let subTextY = '', subTextY1 = '', subTextY2 = '';

          if (metric === 'm') {
              let denY = getDenom(yObj.minWk);
              let denY1 = getDenom(y1Obj.minWk);
              let denY2 = getDenom(y2Obj.minWk);
              let denY3 = getDenom(y3Obj.minWk);
              
              yoyValY = agg === 'avg' ? (denY > 0 ? yObj.m / denY : 0) : yObj.m;
              yoyValY1 = agg === 'avg' ? (denY1 > 0 ? y1Obj.m / denY1 : 0) : y1Obj.m;
              yoyValY2 = agg === 'avg' ? (denY2 > 0 ? y2Obj.m / denY2 : 0) : y2Obj.m;
              yoyValY3 = agg === 'avg' ? (denY3 > 0 ? y3Obj.m / denY3 : 0) : y3Obj.m;

              subTextY = yoyValY !== 0 ? Math.round(yoyValY).toLocaleString() : '-';
              subTextY1 = yoyValY1 !== 0 ? Math.round(yoyValY1).toLocaleString() : '-';
              subTextY2 = yoyValY2 !== 0 ? Math.round(yoyValY2).toLocaleString() : '-';
          } else {
              subTextY = yObj.q > 0 ? Math.round(yObj.v / yObj.q).toLocaleString() : '-';
              subTextY1 = y1Obj.q > 0 ? Math.round(y1Obj.v / y1Obj.q).toLocaleString() : '-';
              subTextY2 = y2Obj.q > 0 ? Math.round(y2Obj.v / y2Obj.q).toLocaleString() : '-';
          }

          let avgShtgY = yObj.shtg_cnt > 0 ? (yObj.shtg_sum / yObj.shtg_cnt) : 0;
          let avgShtgY1 = y1Obj.shtg_cnt > 0 ? (y1Obj.shtg_sum / y1Obj.shtg_cnt) : 0;
          let avgShtgY2 = y2Obj.shtg_cnt > 0 ? (y2Obj.shtg_sum / y2Obj.shtg_cnt) : 0;

          let revY = (avgShtgY < 1 && avgShtgY >= 0) ? valY / (1 - avgShtgY) : valY;
          let revY1 = (avgShtgY1 < 1 && avgShtgY1 >= 0) ? valY1 / (1 - avgShtgY1) : valY1;
          let revY2 = (avgShtgY2 < 1 && avgShtgY2 >= 0) ? valY2 / (1 - avgShtgY2) : valY2;

          function renderCell(val, yoyHtml, subHtml, shtgPct, revVal) {
             if (val === 0 && yoyHtml === '') return '-';

             let sText = shtgPct > 0 ? `S: ${(shtgPct * 100).toFixed(1)}%` : '';
             let sColor = shtgPct > 0 ? getShtgColor(shtgPct) : '';
             let sHtml = shtgPct > 0 ? `<span style="color:${sColor}; font-weight:800;">${sText}</span>` : `<span></span>`;

             if (metric === 'p') {
                 let rText = shtgPct > 0 ? `[${formatValue(revVal, isMicro)}]` : '';
                 return `<div style="display:flex; flex-direction:column; justify-content:space-between; min-height:36px; height:100%; padding:2px;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <span style="font-size:0.75rem; font-weight:700; color:#94a3b8;">${rText}</span>
                        <span style="text-align:right; font-size:0.85rem;">${formatValue(val, isMicro)}</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:0.7rem; font-weight:700; margin-top:4px; align-items: flex-end;">
                        ${sHtml}
                        <span style="text-align:right;">${yoyHtml}</span>
                    </div></div>`;
             } else {
                 let subStr = (subHtml !== '' && subHtml !== '-') ? `[₹${subHtml}]` : '';
                 return `<div style="display:flex; flex-direction:column; justify-content:space-between; min-height:36px; height:100%; padding:2px;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                        <span style="font-size:0.75rem; font-weight:700; color:#64748b;">${subStr}</span>
                        <span style="text-align:right; font-size:${metric==='m' ? '1rem' : '0.85rem'};">${formatValue(val, isMicro)}</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:0.75rem; font-weight:700; margin-top:4px; align-items: flex-end;">
                        ${sHtml}
                        <span style="text-align:right;">${yoyHtml}</span>
                    </div></div>`;
             }
          }

          let cellY = renderCell(valY, renderYoYHTML(yoyValY, yoyValY1, metric === 'p', false), subTextY, avgShtgY, revY);
          let cellY1 = renderCell(valY1, renderYoYHTML(yoyValY1, yoyValY2, metric === 'p', false), subTextY1, avgShtgY1, revY1);
          let cellY2 = renderCell(valY2, renderYoYHTML(yoyValY2, yoyValY3, metric === 'p', true), subTextY2, avgShtgY2, revY2); 

          html += `<td>${cellY}</td><td style="background-color:#f8fafc;">${cellY1}</td><td class="col-divider">${cellY2}</td>`;
        });
        return html + `</tr>`;
      }

      let grandTotalBadge = totalActiveModels.size > 0 ? `<span style="margin-left:auto; color:#475569; font-size:0.7rem; font-weight:800; padding-left:10px; flex-shrink:0;">📦 (${totalActiveModels.size})</span>` : '';
      let finalHtml = buildRowHtml('GRAND TOTAL (Filtered)' + grandTotalBadge, grandTotal, false, true);
      
      flatRowsToRender.forEach(child => {
         let dispName = "";
         let rText = "";
         let safeChildName = String(child.name || '');

         if (child.type === 'mod') {
            let mCode = safeChildName.includes('::') ? safeChildName.split('::')[1].trim().toUpperCase() : safeChildName.trim().toUpperCase();
            rText = modelRangeMap[mCode] || "";
         } else if (child.type === 'itm') {
            if (itemRangeMap[child.code]) {
                let safeRange = String(itemRangeMap[child.code]);
                rText = "R " + safeRange.replace(/\D/g, '');
            }
         }
         let rangeBadge = rText ? `<span class="pct-badge" style="background:#fef3c7; border-color:#fde68a; color:#92400e;">${rText}</span>` : '';
         
         let padding = child.level * 20; 
         let hasActualChildren = Object.keys(child.children).length > 0;
         let toggleIcon = '';
         
         if (hasActualChildren) { 
             let isExp = expandedNodes.has(child.id);
             let safeId = encodeSafeId(String(child.id));
             toggleIcon = `<span class="expand-btn" onclick="toggleTreeNode('${safeId}', event)">${isExp ? '−' : '+'}</span>`;
         } else { toggleIcon = `<span class="level-dot"></span>`; }
         
         let pctBadge = child.pctCont ? `<span class="pct-badge">${child.pctCont}</span>` : '';
         let rightBadge = (child.type !== 'mod' && child.type !== 'itm' && child.activeModels.size > 0) 
            ? `<span style="margin-left:auto; color:#94a3b8; font-size:0.65rem; font-weight:700; padding-right:10px;">📦 (${child.activeModels.size})</span>` : '';
         
         dispName = `<div style="padding-left:${padding}px; display:flex; align-items:center; width:100%; box-sizing:border-box;">${toggleIcon} <span style="white-space:normal; line-height:1.2;">${formatName(safeChildName)}</span> ${pctBadge} ${rangeBadge} ${rightBadge}</div>`;
         
         finalHtml += buildRowHtml(dispName, child.chans, child.isMicroLevel, false);
      });
      
      tbody.innerHTML = finalHtml;
    }

    function toggleInsights() {
        const panel = document.getElementById('insights-panel');
        panel.classList.toggle('active');
    }

    // UPDATED WITH calcValueCallback TO PREVENT SCOPE REFERENCE ERROR
    function generateInsights(visibleRows, grandTotalAgg, metric, endWk, calcValueCallback) {
        const container = document.getElementById('insights-container');
        container.innerHTML = '';
        if (visibleRows.length === 0) return;

        const startWk = parseInt(document.getElementById('f-start').value) || 1;
        let isMicro = (metric === 'p');

        let performers = { spt:{}, dep:{}, sdep:{}, fam:{}, typ:{} };
        let modelMarginMap = {};
        let modelShortageMap = {};
        let rangeShiftMap = {};
        let globalVolumeY = 0, globalVolumeY1 = 0, globalVolumeY2 = 0;

        filteredData.forEach(r => {
            let mCode = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[1].trim().toUpperCase() : String(r.mod || 'UNK').toUpperCase();
            let rawMName = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[0].trim() : String(r.mod || '');
            let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm || '').trim().toUpperCase();
            if(!iCode) iCode = mCode;

            let v = r.preAgg.y.v;
            let q = r.preAgg.y.q;
            let mValue = r.preAgg.y.m;

            globalVolumeY += r.preAgg.y.q;
            globalVolumeY1 += r.preAgg.y1.q;
            globalVolumeY2 += r.preAgg.y2.q;

            ['spt', 'dep', 'sdep', 'fam', 'typ'].forEach(h => {
                if(r[h]) {
                    let safeVal = String(r[h]);
                    performers[h][safeVal] = (performers[h][safeVal] || 0) + v;
                }
            });

            modelMarginMap[rawMName] = (modelMarginMap[rawMName] || 0) + mValue;

            if(!modelShortageMap[rawMName]) modelShortageMap[rawMName] = { sum:0, cnt:0 };
            modelShortageMap[rawMName].sum += r.preAgg.y.shtg_sum;
            modelShortageMap[rawMName].cnt += r.preAgg.y.shtg_cnt;

            if(!rangeShiftMap[mCode]) {
                rangeShiftMap[mCode] = { name: rawMName, activeWks: 0, rngStr: String(r.trueRng || r.rng || ''), pwpsVal: 0 };
            }
