        potentialList.sort((a,b) => b.val - a.val);
        let top5Potential = potentialList.slice(0, 5);
        let potentialCard = `
        <div class="insight-card" style="border-left-color: #8b5cf6;">
            <div class="insight-title">🚀 Top 5 Sales Potentials (PWPS)</div>
            <div class="insight-text">Active high-velocity configurations sorted by aggregate pipeline potential:</div>
            <div style="margin-top:8px;">
               ${top5Potential.map((p, i) => `<div class="insight-row-item"><span>${i+1}. ${p.name}</span> <b>${metric === 'p' ? p.val.toFixed(1)+' u' : '₹'+Math.round(p.val).toLocaleString()}</b></div>`).join('')}
            </div>
        </div>`;

        let shortageAlerts = Object.entries(modelShortageMap).map(([name, d]) => ({
            name: String(name), rate: d.cnt > 0 ? d.sum / d.cnt : 0
        })).filter(x => x.rate > 0).sort((a,b) => b.rate - a.rate).slice(0, 3);
        
        let shortageCard = `
        <div class="insight-card" style="border-left-color: #ef4444;">
            <div class="insight-title">🚨 Supply Scarcity & Leakage Alerts</div>
            <div class="insight-text">Top critical out-of-stock leakages blocking realized turnover:</div>
            <div style="margin-top:8px;">
               ${shortageAlerts.map((s, i) => `<div class="insight-row-item"><span>${i+1}. ${s.name}</span> <span style="color:#dc2626; font-weight:700;">${(s.rate*100).toFixed(1)}% Scarcity</span></div>`).join('')}
            </div>
        </div>`;

        let deviationsList = [];
        let pStart = Math.max(1, currentISOWeek - 4), pEnd = Math.max(1, currentISOWeek - 1);
        let fStart = currentISOWeek, fEnd = Math.min(53, currentISOWeek + 3);

        allData.forEach(r => {
            let mCode = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[1].trim().toUpperCase() : String(r.mod || '').trim().toUpperCase();
            let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm || '').trim().toUpperCase();
            if(!iCode) iCode = mCode;
            let rawMName = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[0].trim() : String(r.mod || '');

