        let trajectoryText = "Stable continuous performance profile detected across historical baselines.";
        if (globalVolumeY > 0 && globalVolumeY1 > 0 && globalVolumeY2 > 0) {
            if (globalVolumeY > globalVolumeY1 && globalVolumeY1 > globalVolumeY2) {
                trajectoryText = `📈 <b>Linear Acceleration Pattern Identified:</b> This portfolio has sustained compound trajectory expansion across the past 3 seasons (Y-2: ${Math.round(globalVolumeY2).toLocaleString()} u ➔ Y-1: ${Math.round(globalVolumeY1).toLocaleString()} u ➔ Current Y: ${Math.round(globalVolumeY).toLocaleString()} u).`;
            } else if (globalVolumeY < globalVolumeY1 && globalVolumeY1 < globalVolumeY2) {
                trajectoryText = `📉 <b>Systemic Degradation Pattern Identified:</b> Steady structural trajectory collapse over 3 consecutive seasons. Immediate category review requested.`;
            } else if (globalVolumeY < (globalVolumeY1 * 0.7) && globalVolumeY1 > 0) {
                trajectoryText = `⚠️ <b>Window Cliff-Drop Detected:</b> Current year baseline exhibits an abnormal -30% deviation compared to identical multi-year timelines. Check allocation constraints or structural logistics bugs.`;
            }
        }

        let trajectoryCard = `
        <div class="insight-card" style="border-left-color: #ec4899; grid-column: span 2;">
            <div class="insight-title">🔄 3-Year Parallel Trajectory Analysis</div>
            <div class="insight-text">${trajectoryText}</div>
        </div>`;

        container.innerHTML = hierarchyCard + marginCard + potentialCard + shortageCard + velocityCard + prescriptiveCard + trajectoryCard;
    }

    function promptCalcTraceExport() {
        let mCode = prompt("Enter Model Code to Trace (e.g. 8784634):");
        if(!mCode) return;
        mCode = String(mCode).trim().toUpperCase();
        
        let startWk = parseInt(document.getElementById('f-start').value) || 1;
        let endWk = parseInt(document.getElementById('f-end').value) || 53;
        
        let traceData = [];
        let pushTrace = (c1, c2, c3, c4, c5) => traceData.push([c1, c2, c3, c4, c5]);

        pushTrace("METADATA", "Model Code Trace", mCode, "", "Auditing PWPS Extrapolation & Math");
        pushTrace("", "", "", "", "");
        pushTrace("Level / Identifier", "Step Description", "Reason (The Why)", "No. of Stores Considered", "Calculated Value");
        
        let modelRows = allData.filter(r => {
            let mc = (r.mod && String(r.mod).includes('::')) ? String(r.mod).split('::')[1].trim().toUpperCase() : String(r.mod || '').trim().toUpperCase();
            return mc === mCode;
        });
        
        if(modelRows.length === 0) { alert("Model not found in the current data lake."); return; }
        
        let itemYTD = {};
        let localModelWkMap = {y: 99, y1: 99, y2: 99, y3: 99};

        // Strict historical pass for auditing engine
        modelRows.forEach(r => {
            let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm || '').trim().toUpperCase();
            if(!iCode) iCode = mCode;
            let rCh = String(r.ch).trim().toUpperCase();
            let famCode = (r.fam && String(r.fam).includes('::')) ? String(r.fam).split('::')[1].trim().toUpperCase() : String(r.fam || '').trim().toUpperCase();
            
            if (!itemYTD[iCode]) itemYTD[iCode] = { famCode: famCode, chans: {} };
            if (!itemYTD[iCode].chans['OVERALL']) itemYTD[iCode].chans['OVERALL'] = { y:{}, y1:{}, y2:{}, y3:{} };
            if (!itemYTD[iCode].chans[rCh]) itemYTD[iCode].chans[rCh] = { y:{}, y1:{}, y2:{}, y3:{} };
            
            for(let w = 1; w <= 53; w++) {
                ['y', 'y1', 'y2', 'y3'].forEach((yKey, idx) => {
                    let yr = maxYear - idx;
                    let wkStr = `${w}.${yr}`;
                    
                    let actualQ = r.w[wkStr] ? (r.w[wkStr].q || 0) : 0;
                    let actualV = r.w[wkStr] ? (r.w[wkStr].v || 0) : 0;

                    if (actualQ > 0 || actualV !== 0) {
                        localModelWkMap[yKey] = Math.min(localModelWkMap[yKey], w); 
                        
                        let currentRngNum = parseInt(String(r.rng || '').replace(/\D/g, '')) || 4;
                        if (!itemYTD[iCode].chans['OVERALL'][yKey][w]) itemYTD[iCode].chans['OVERALL'][yKey][w] = {v:0, q:0, rng: currentRngNum};
                        else itemYTD[iCode].chans['OVERALL'][yKey][w].rng = Math.min(itemYTD[iCode].chans['OVERALL'][yKey][w].rng, currentRngNum);
                        
                        itemYTD[iCode].chans['OVERALL'][yKey][w].v += actualV;
                        itemYTD[iCode].chans['OVERALL'][yKey][w].q += actualQ;
                        
                        if (rCh !== 'FORECAST_DUMMY') {
                            if (!itemYTD[iCode].chans[rCh][yKey][w]) itemYTD[iCode].chans[rCh][yKey][w] = {v:0, q:0};
                            itemYTD[iCode].chans[rCh][yKey][w].v += actualV;
                            itemYTD[iCode].chans[rCh][yKey][w].q += actualQ;
                        }
                    }
                });
            }
        });
        
        let modelTotalPWPS = { v: 0, q: 0 };
        
        Object.keys(itemYTD).forEach(iCode => {
            let itmData = itemYTD[iCode];
            let overallCh = itmData.chans['OVERALL'];

            ['OVERALL'].concat(targetChannels).forEach(ch => {
                let chKey = String(ch).trim().toUpperCase();
                if(!itmData.chans[chKey]) return;
                
                let yKey = 'y'; 
                let overallWkMap = overallCh[yKey];
                let chWkMap = itmData.chans[chKey][yKey];
                
                let activeStart = localModelWkMap[yKey] === 99 ? startWk : localModelWkMap[yKey];
                let activeWeeks = endWk - Math.max(startWk, activeStart) + 1;
                
                let total_v = 0, total_q = 0, total_store_weeks = 0;
                let lastKnownRngNum = 4;
                if(itemRangeMap[iCode]) lastKnownRngNum = parseInt(String(itemRangeMap[iCode]).replace(/\D/g, '')) || 4;
                
                for (let w = Math.max(startWk, activeStart); w <= endWk; w++) {
                    if (overallWkMap[w] && overallWkMap[w].rng) lastKnownRngNum = overallWkMap[w].rng;
                    let wkStores = (w >= activeStart) ? getBlendedStoreCountForWeek(maxYear, w, itmData.famCode, lastKnownRngNum) : 0;
                    total_store_weeks += wkStores;
                    
                    if (chWkMap[w]) {
                        total_v += chWkMap[w].v;
                        total_q += chWkMap[w].q;
                    }
                }
                
                let avgStores = activeWeeks > 0 ? total_store_weeks / activeWeeks : 0;
                let aws_v = activeWeeks > 0 ? total_v / activeWeeks : 0;
                let aws_q = activeWeeks > 0 ? total_q / activeWeeks : 0;
                
                let pwps_v = avgStores > 0 ? aws_v / avgStores : 0;
                let pwps_q = avgStores > 0 ? aws_q / avgStores : 0;

                if(total_q > 0 || total_v > 0) {
                    pushTrace(`ITEM: ${iCode} | CH: ${chKey}`, `1. Find Model Launch Week`, `A physical product launches when the Model launches. All sizes inherit the Model's first week of sale.`, ``, `Wk ${activeStart}`);
                    pushTrace(``, `2. Calculate Active Weeks`, `(End Week - Launch Week + 1). Defines the exact lifespan denominator.`, ``, `${activeWeeks} wks`);
                    pushTrace(``, `3. Sum Total Volume`, `Aggregates realized sales and future extrapolated forecast over the active weeks.`, ``, `Qty: ${Math.round(total_q)} | Val: ${Math.round(total_v)}`);
                    pushTrace(``, `4. Sum Store-Weeks`, `Aggregates the physical store footprint week-on-week over the active lifespan.`, `${avgStores.toFixed(1)} stores`, `${Math.round(total_store_weeks)} store-weeks`);
                    pushTrace(``, `5. Final PWPS Math`, `Total Volume / (Total Store-Weeks / Active Weeks). Yields true Sales Potential.`, ``, `Q: ${pwps_q.toFixed(2)} | V: ${Math.round(pwps_v)}`);
                    pushTrace("", "", "", "", "");

                    if (chKey === 'OVERALL') {
                        modelTotalPWPS.q += pwps_q;
                        modelTotalPWPS.v += pwps_v;
                    }
                }
            });
        });
        
        pushTrace(`MODEL: ${mCode}`, `1. PWPS Rollup Aggregation`, `Pure summation of independent item PWPS calculations to prevent clearance-skew and average distortions.`, ``, `Q: ${modelTotalPWPS.q.toFixed(2)} | V: ${Math.round(modelTotalPWPS.v)}`);

        let btn = document.getElementById('btn-calc-export');
        if(btn) { btn.disabled = true; btn.textContent = '⏳ Exporting...'; }
        
        google.script.run.withSuccessHandler(res => {
            if(btn) { btn.disabled = false; btn.textContent = '🧮 Trace PWPS Math'; }
            alert(res);
        }).withFailureHandler(err => {
            if(btn) { btn.disabled = false; btn.textContent = '🧮 Trace PWPS Math'; }
            alert("Trace Error: " + err.message);
        }).exportCalcTraceBackend(mCode, JSON.stringify(traceData));
    }

