        deviationsList.forEach(d => { if(!uniqueDev[d.name]) uniqueDev[d.name] = d; else { uniqueDev[d.name].past += d.past; uniqueDev[d.name].fut += d.fut; uniqueDev[d.name].delta = uniqueDev[d.name].fut - uniqueDev[d.name].past; }});
        let finalDevList = Object.values(uniqueDev).sort((a,b) => Math.abs(b.delta) - Math.abs(a.delta)).slice(0, 3);
        
        let velocityCard = `
        <div class="insight-card" style="border-left-color: #f59e0b;">
