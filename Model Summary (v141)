    function executeFilterEngine() {
      const term = document.getElementById('global-search').value.toLowerCase();
      
      filteredData = cachedYTD.filter(r => {
        if(term) {
          let rowString = `${r.rng} ${r.abc} ${r.spt} ${r.dep} ${r.sdep} ${r.nop} ${r.dsm} ${r.fam} ${r.mod} ${r.itm} ${r.typ} ${r.grp}`.toLowerCase();
          if(!rowString.includes(term)) return false;
        }
        for(let key in selectedFilters) {
          // EXPLICIT STRICT EQUALITY SAFETY CASTING
          let valToCheck = String((key === 'rng') ? r.trueRng || '' : r[key] || '');
          if(selectedFilters[key].length > 0 && !selectedFilters[key].includes(valToCheck)) return false;
        }
        return true;
      });

      filterDefs.forEach(def => {
        if(def.id === activePanelId) return; 
        let validOptions = new Set(filteredData.map(r => String((def.id === 'rng') ? r.trueRng || '' : r[def.id] || '')).filter(Boolean));
        let listHtml = '';
        Array.from(validOptions).sort().forEach(val => {
          let isChecked = selectedFilters[def.id].includes(val) ? 'checked' : '';
          let safeVal = String(val).replace(/"/g, '&quot;');
          let displayVal = String(val).includes('::') ? `${String(val).split('::')[0]} <span style="color:#94a3b8; font-size:0.75rem;">[${String(val).split('::')[1]}]</span>` : val;
          listHtml += `<label class="checkbox-item" onclick="event.stopPropagation()"><input type="checkbox" value="${safeVal}" ${isChecked} onchange="handleCheck('${def.id}', this.value)">${displayVal}</label>`;
        });
        document.getElementById(`list-${def.id}`).innerHTML = listHtml;
      });
      renderTable();
    }

