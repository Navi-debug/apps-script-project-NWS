        let marginCard = `
        <div class="insight-card" style="border-left-color: #10b981;">
            <div class="insight-title">💰 Top Cash Profit Drivers</div>
            <div class="insight-text">Isolating top drivers by absolute cash volume rather than percentage distortion:</div>
            <div style="margin-top:8px;">
               ${topMargins.map((m, i) => `<div class="insight-row-item"><span>${i+1}. ${String(m[0])}</span> <b>₹${Math.round(m[1]).toLocaleString()}</b></div>`).join('')}
            </div>
        </div>`;

        let potentialList = [];
