    window.closeExportModal = function() { document.getElementById('export-modal').style.display = 'none'; };

    // --- LIGHTWEIGHT DIRECT EXPORT ENGINE DECOUPLED FROM BACKGROUND LOOPS ---
    function runExportEngine(forceOverwrite = false) {
      let tabName = document.getElementById('exp-tab-name').value.trim() || 'Custom_Export';
      let levelSelect = document.getElementById('exp-level');
      let level = levelSelect.value;
      let year = document.getElementById('exp-year').value;
      
      let depthNodes = document.getElementsByName('exp-depth');
      let depthMode = 'overall';
      for(let i=0; i<depthNodes.length; i++) { if(depthNodes[i].checked) depthMode = depthNodes[i].value; }
      
      let isWow = (depthMode === 'wow');
      let isFiltered = (depthMode === 'filtered');
      
      let metrics = [];
      if(document.getElementById('exp-m-v').checked) metrics.push({id: 'v', label: 'Sales Value'});
      if(document.getElementById('exp-m-q').checked) metrics.push({id: 'q', label: 'Sales Qty'});
      if(document.getElementById('exp-m-asp').checked) metrics.push({id: 'asp', label: 'ASP'});
      if(document.getElementById('exp-m-mabs').checked) metrics.push({id: 'm_abs', label: 'Margin Val'});
      if(document.getElementById('exp-m-mpct').checked) metrics.push({id: 'm_pct', label: 'Margin %'});
      if(document.getElementById('exp-m-pwps').checked) metrics.push({id: 'pwps', label: 'Sales Potential (PWPS)'});

      if(metrics.length === 0) { alert("Please select at least one metric."); return; }

      let btn = document.getElementById('btn-run-export');
      btn.disabled = true; btn.textContent = "⏳ Generating...";

      const hierarchy = [
        { id: 'spt', cols: ['Sport'] }, { id: 'dep', cols: ['Department'] },
        { id: 'sdep', cols: ['SubDepartment'] }, { id: 'fam', cols: ['Family Name', 'Family Code'] },
        { id: 'typ', cols: ['Typology'] }, { id: 'dsm', cols: ['DSM Name', 'DSM Code'] },
        { id: 'mod', cols: ['Model Name', 'Model Code'] }, { id: 'itm', cols: ['Item Name', 'Item Code'] }
      ];

      let targetIndex = hierarchy.findIndex(h => h.id === level);
      if(targetIndex === -1) targetIndex = hierarchy.length - 1;
      let pathConfig = hierarchy.slice(0, targetIndex + 1);
      
      const startWk = parseInt(document.getElementById('f-start').value) || 1;
      const endWk = parseInt(document.getElementById('f-end').value) || 53;
      let yKeyMap = { [maxYear]: 'y', [maxYear-1]: 'y1', [maxYear-2]: 'y2', [maxYear-3]: 'y3' };
      let yKey = yKeyMap[year] || 'y';

      let grouped = {};
      filteredData.forEach(r => {
         let keyParts = pathConfig.map(h => String((h.id === 'rng' ? r.trueRng : r[h.id]) || 'UNASSIGNED'));
         let key = keyParts.join('|');
         let iCode = (r.itm && String(r.itm).includes('::')) ? String(r.itm).split('::')[1].trim().toUpperCase() : String(r.itm ? r.itm : (r.mod ? r.mod : 'UNK')).trim().toUpperCase();

         if (!grouped[key]) {
            grouped[key] = { pathData: keyParts, items: new Set() };
         }
         grouped[key].items.add(iCode);
      });

      Object.keys(grouped).forEach(k => {
         let g = grouped[k];
         g.w = {};
         for(let w=1; w<=53; w++) g.w[w] = {v:0, q:0, m:0, shtg_sum:0, shtg_cnt:0};
         g.overall = {v:0, q:0, m:0, shtg_sum:0, shtg_cnt:0, pwps_v:0, pwps_q:0};
         g.minWk = 99;

         g.items.forEach(ic => {
            let iData = itemYTD[ic];
            if(!iData || !iData.chans['OVERALL'] || !iData.chans['OVERALL'][yKey]) return;

            let wDataMap = iData.chans['OVERALL'][yKey];
            
            let activeStart = modelMinWkMap[iData.mCode] ? modelMinWkMap[iData.mCode][yKey] : 99;
            if(activeStart === 99) activeStart = startWk;
            g.minWk = Math.min(g.minWk, activeStart);

            for(let w=1; w<=53; w++) {
                let wkData = wDataMap[w];
                if(wkData) {
                    g.w[w].v += wkData.v;
                    g.w[w].q += wkData.q;
                    g.w[w].m += (wkData.m || 0);

                    let shouldInclude = false;
                    if (isFiltered && w >= startWk && w <= endWk) shouldInclude = true;
                    if (!isFiltered) shouldInclude = true;

                    if (shouldInclude) {
                        g.overall.v += wkData.v;
                        g.overall.q += wkData.q;
                        g.overall.m += (wkData.m || 0);
                    }
                }

                let wkStr = `${w}.${year}`;
                let mCode = iData.mCode;
                let sVal = globalShortageMap[ic] && globalShortageMap[ic][wkStr] !== undefined ? globalShortageMap[ic][wkStr] : 
                           (globalShortageMap[mCode] && globalShortageMap[mCode][wkStr] !== undefined ? globalShortageMap[mCode][wkStr] : undefined);

                if (sVal !== undefined) {
                    g.w[w].shtg_sum += sVal;
                    g.w[w].shtg_cnt += 1;
                    
                    let shouldIncludeShtg = false;
                    if (isFiltered && w >= startWk && w <= endWk) shouldIncludeShtg = true;
                    if (!isFiltered) shouldIncludeShtg = true;
                    
                    if (shouldIncludeShtg) {
                        g.overall.shtg_sum += sVal;
                        g.overall.shtg_cnt += 1;
                    }
                }
            }

            if (globalItemPWPS[ic] && globalItemPWPS[ic]['OVERALL'] && globalItemPWPS[ic]['OVERALL'][yKey]) {
                g.overall.pwps_v += globalItemPWPS[ic]['OVERALL'][yKey].pwps_v;
                g.overall.pwps_q += globalItemPWPS[ic]['OVERALL'][yKey].pwps_q;
            }
         });
      });

      let exportArray = []; let headerRow = [];
      pathConfig.forEach(h => headerRow.push(...h.cols));
      
      if (!isWow) {
         metrics.forEach(m => {
            if (m.id === 'pwps') headerRow.push('PWPS Realized', 'Average Shortage %', 'PWPS Revised');
            else headerRow.push(m.label + (isFiltered ? ` (Wk ${startWk}-${endWk})` : ''));
         });
      } else {
         metrics.forEach(m => {
            for(let w = 1; w <= 53; w++) {
                if (m.id === 'pwps') headerRow.push(`W${w} PWPS Realized`, `W${w} Shortage %`, `W${w} PWPS Revised`);
                else headerRow.push(`${m.label} - W${w}`);
            }
         });
      }
      exportArray.push(headerRow);

      Object.keys(grouped).forEach(k => {
         let g = grouped[k]; let rowData = [];
         g.pathData.forEach((val, idx) => {
            let h = pathConfig[idx];
            if (h.cols.length === 2) {
               let name = String(val), code = '';
               if (name.includes('::')) { let parts = name.split('::'); name = parts[0].trim(); code = parts[1].trim(); }
               rowData.push(name, code);
            } else { rowData.push(String(val)); }
         });

         if (!isWow) {
            metrics.forEach(m => {
               if(m.id === 'v') rowData.push(Math.round(g.overall.v));
               if(m.id === 'q') rowData.push(Math.round(g.overall.q));
               if(m.id === 'asp') rowData.push(g.overall.q > 0 ? Math.round(g.overall.v/g.overall.q) : 0);
               if(m.id === 'm_abs') rowData.push(Math.round(g.overall.m));
               if(m.id === 'm_pct') rowData.push(g.overall.v > 0 ? ((g.overall.m/g.overall.v)*100).toFixed(2) + '%' : '0%');
               if(m.id === 'pwps') {
                   let valPWPS = (level === 'mod' || level === 'itm') ? g.overall.pwps_q : g.overall.pwps_v;
                   let avgShtg = g.overall.shtg_cnt > 0 ? (g.overall.shtg_sum / g.overall.shtg_cnt) : 0;
                   let revPWPS = (avgShtg < 1 && avgShtg >= 0) ? valPWPS / (1 - avgShtg) : valPWPS;
                   rowData.push(valPWPS.toFixed(2)); rowData.push((avgShtg * 100).toFixed(1) + '%'); rowData.push(revPWPS.toFixed(2));
               }
            });
         } else {
            metrics.forEach(m => {
               for(let w = 1; w <= 53; w++) {
                  let wData = g.w[w];
                  
                  if (w < g.minWk) {
                      rowData.push("");
                      if(m.id === 'pwps') { rowData.push(""); rowData.push(""); }
                  } else {
                      if(m.id === 'v') rowData.push(Math.round(wData.v));
                      if(m.id === 'q') rowData.push(Math.round(wData.q));
                      if(m.id === 'asp') rowData.push(wData.q > 0 ? Math.round(wData.v/wData.q) : 0);
                      if(m.id === 'm_abs') rowData.push(Math.round(wData.m));
                      if(m.id === 'm_pct') rowData.push(wData.v > 0 ? ((wData.m/wData.v)*100).toFixed(2) + '%' : '0%');
                      if(m.id === 'pwps') {
                          let valPWPS = 0; 
                          let avgShtg = wData.shtg_cnt > 0 ? (wData.shtg_sum / wData.shtg_cnt) : 0;
                          rowData.push(valPWPS.toFixed(2)); rowData.push((avgShtg * 100).toFixed(1) + '%'); rowData.push(valPWPS.toFixed(2));
                      }
                  }
               }
            });
         }
         exportArray.push(rowData);
      });

      google.script.run.withSuccessHandler(res => {
         if (res === 'EXISTS') {
             let confirmOver = confirm(`A tab named '${tabName}' already exists. Overwrite it?`);
             if (confirmOver) runExportEngine(true); else { btn.disabled = false; btn.textContent = "🚀 Push to Excel"; }
         } else {
             btn.disabled = false; btn.textContent = "🚀 Push to Excel";
             window.closeExportModal(); alert(res);
         }
      }).withFailureHandler(err => {
         btn.disabled = false; btn.textContent = "🚀 Push to Excel"; alert("Export Error: " + err.message);
      }).executeExport(tabName, JSON.stringify(exportArray), forceOverwrite, {source: 'Model Summary'});
    }
    document.addEventListener('click', closeAllPanels);
  </script>
</body>
