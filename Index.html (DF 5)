    function getRootColor(c) {
        if(!c || c==='-') return 'Other'; let txt = String(c).toLowerCase();
        if(/grey|gray|slate|ash|iron|carbon|graphite|zinc/.test(txt)) return 'Grey'; if(/blue|navy|cyan|teal|indigo|aqua/.test(txt)) return 'Blue';
        if(/red|crimson|ruby|maroon|burgundy/.test(txt)) return 'Red'; if(/green|olive|mint|khaki|sage/.test(txt)) return 'Green';
        if(/black|obsidian|dark/.test(txt)) return 'Black'; if(/white|snow|pearl|ivory|cream/.test(txt)) return 'White';
        if(/pink|rose|fuchsia|blush|magenta|salmon/.test(txt)) return 'Pink'; if(/yellow|gold|mustard/.test(txt)) return 'Yellow';
        if(/purple|violet|lavender|plum/.test(txt)) return 'Purple'; if(/orange|coral|peach/.test(txt)) return 'Orange';
        if(/brown|beige|tan|sand|khaki/.test(txt)) return 'Brown/Beige';
        return 'Other';
    }

    function getPriceBucket(p) {
        if(p===0) return 'Unpriced'; if(p<=99) return '0-99'; if(p<=249) return '100-249';
        if(p<=399) return '250-399'; if(p<=599) return '400-599'; if(p<=999) return '600-999';
        if(p<=1599) return '1000-1599'; if(p<=2499) return '1600-2499'; if(p<=3999) return '2500-3999'; return '4000+';
    }

    function updateInsightsView() {
      let metric = $('#perf-metric').val(); let month = $('#perf-month').val(); let week = $('#perf-week').val();
      let year = $('#perf-year').val(); const getZero = () => ({ mkpl26:0, mkpl25:0, qc26:0, qc25:0, b2b26:0, b2b25:0 });

      let fMaster = globalMasterData.filter(checkGlobalFlt);
      let fPerf = globalPerfData.filter(checkGlobalFlt);

      currentPerfMap = {}; currentMasterMap = {};
      fMaster.forEach(m => { currentMasterMap[m.code] = m; });

      fPerf.forEach(p => {
         let cur = getZero();
         if(month !== "" && p.months[month]) cur = p.months[month][metric] || getZero();
         else if(week !== "" && p.weeks[week]) cur = p.weeks[week][metric] || getZero();
         else if(month === "" && week === "") cur = (year === '2025') ? (p.fy25[metric]||getZero()) : (p.ytd[metric]||getZero());

         let ty = (year==='2026'?cur.b2b26:cur.b2b25) + (year==='2026'?cur.qc26:cur.qc25) + (year==='2026'?cur.mkpl26:cur.mkpl25);
         let ly = cur.b2b25 + cur.qc25 + cur.mkpl25;
         currentPerfMap[p.code] = { ty: ty, ly: ly };
      });

      let secNopVol = {}; 
      let priceVol = { '0-99':0, '100-249':0, '250-399':0, '400-599':0, '600-999':0, '1000-1599':0, '1600-2499':0, '2500-3999':0, '4000+':0, 'Unpriced':0 };
      let genderVol = {};
      globalOpeData = {};
      let availableNops = new Set();
      let globalTotalTy = 0;

      for (let code in currentPerfMap) {
         let m = currentMasterMap[code]; if(!m) continue;
         let ty = currentPerfMap[code].ty; let ly = currentPerfMap[code].ly;
         if (ty === 0 && ly === 0) continue;

         let sec = m.sector || 'Unknown'; let nop = m.nop || 'Unknown'; availableNops.add(nop);
         let pStr = String(m.cataloguePrice || '').replace(/,/g, '').replace(/[^\d.]/g, '');
         let price = parseFloat(pStr) || 0; let pBucket = getPriceBucket(price);
         let rColor = getRootColor(m.color);
         let gen = m.finalGender || 'Unknown';

         globalTotalTy += ty;

         if(!secNopVol[sec]) secNopVol[sec] = {};
         secNopVol[sec][nop] = (secNopVol[sec][nop] || 0) + ty;
         
         priceVol[pBucket] += ty;
         genderVol[gen] = (genderVol[gen] || 0) + ty;
         
         let opeKey = `${nop}|${gen}|${rColor}|${pBucket}`;
         if(!globalOpeData[opeKey]) globalOpeData[opeKey] = {nop: nop, gen: gen, col: rColor, allColors: new Set(), prc: pBucket, ty:0, ly:0};
         globalOpeData[opeKey].ty += ty; globalOpeData[opeKey].ly += ly;
         if(m.color && m.color !== '-') globalOpeData[opeKey].allColors.add(m.color.toLowerCase());
      }

      // Update OPE NOP Dropdowns
      let colorNopSel = $('#color-nop-filter'); let opeNopSel = $('#ope-nop-filter');
      let cVal = colorNopSel.val() || []; let oVal = opeNopSel.val() || [];
      colorNopSel.empty(); opeNopSel.empty();
      [...availableNops].sort().forEach(n => { colorNopSel.append(new Option(n, n, false, cVal.includes(n))); opeNopSel.append(new Option(n, n, false, oVal.includes(n))); });
      
      // Render 1: NOP Sector Bar Chart
      let sortedSecs = Object.keys(secNopVol).sort((a,b) => Object.values(secNopVol[b]).reduce((x,y)=>x+y,0) - Object.values(secNopVol[a]).reduce((x,y)=>x+y,0)).slice(0,3);
      let dsNop = []; let labelsNop = ['Rank 1', 'Rank 2', 'Rank 3', 'Rank 4', 'Rank 5'];
      const bgColors = ['rgba(59, 130, 246, 0.8)', 'rgba(16, 185, 129, 0.8)', 'rgba(139, 92, 246, 0.8)'];
      
      sortedSecs.forEach((sec, idx) => {
         let topNops = Object.entries(secNopVol[sec]).sort((a,b) => b[1] - a[1]).slice(0,5);
         let dataPoints = []; topNops.forEach(n => dataPoints.push(n[1]));
         dsNop.push({ label: sec, data: dataPoints, backgroundColor: bgColors[idx], topLabels: topNops.map(n=>n[0]) });
      });

      if(cNop) cNop.destroy();
      cNop = new Chart(document.getElementById('chart-nop'), {
         type: 'bar',
         data: { labels: labelsNop, datasets: dsNop },
         options: { responsive: true, maintainAspectRatio: false, 
            plugins: { 
               tooltip: { callbacks: { label: function(c) { return c.dataset.topLabels[c.dataIndex] + ': ' + fmt.format(c.raw); } } },
               datalabels: { display: true, color: 'white', font: { weight: 'bold', size: 10 }, formatter: function(value, context) { return context.dataset.topLabels[context.dataIndex] || ''; } }
            } 
         }
      });

      // Render 2: Price Horizontal Bar
      let pDataArr = Object.keys(priceVol).filter(k => priceVol[k] > 0).map(k => ({label: k, val: priceVol[k]}));
      pDataArr.sort((a,b) => b.val - a.val); 
      let pLabels = pDataArr.map(d => d.label); let pData = pDataArr.map(d => d.val);
      let totalP = pData.reduce((a,b)=>a+b, 0);

      if(cPrice) cPrice.destroy();
      cPrice = new Chart(document.getElementById('chart-price'), {
         type: 'bar',
         data: { labels: pLabels, datasets: [{ label: 'Volume', data: pData, backgroundColor: '#3b82f6' }] },
         options: { 
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { 
               legend: { display: false },
               datalabels: { display: true, color: 'black', align: 'right', anchor: 'end', font: { weight: 'bold', size: 10 }, formatter: function(value) { return fmt.format(value) + ' (' + ((value/totalP)*100).toFixed(1) + '%)'; } }
            },
            scales: { x: { grace: '15%' } } 
         }
      });

      // Render 3: Gender Horizontal Bar 
      let gDataArr = Object.keys(genderVol).filter(k => genderVol[k] > 0).map(k => ({label: k, val: genderVol[k]}));
      gDataArr.sort((a,b) => b.val - a.val); 
      let gLabels = gDataArr.map(d => d.label); let gData = gDataArr.map(d => d.val);
      let totalG = gData.reduce((a,b)=>a+b, 0);

      if(cGender) cGender.destroy();
      cGender = new Chart(document.getElementById('chart-gender'), {
         type: 'bar',
         data: { labels: gLabels, datasets: [{ label: 'T.O / Volume', data: gData, backgroundColor: '#8b5cf6' }] },
         options: { 
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { 
               legend: { display: false },
               datalabels: { display: true, color: 'black', align: 'right', anchor: 'end', font: { weight: 'bold', size: 10 }, formatter: function(value) { return fmt.format(value) + ' (' + ((value/totalG)*100).toFixed(1) + '%)'; } }
            },
            scales: { x: { grace: '15%' } } 
         }
      });

      renderColorChart(); 
      renderOpeTable(globalTotalTy);
    }

    function renderColorChart() {
       let selectedNops = $('#color-nop-filter').val() || [];
       let colorVol = {};
       
       for (let code in currentPerfMap) {
          let m = currentMasterMap[code]; if(!m) continue;
          if(selectedNops.length > 0 && !selectedNops.includes(m.nop)) continue;
          let rColor = getRootColor(m.color);
          if(!colorVol[rColor]) colorVol[rColor] = {ty:0, ly:0};
          colorVol[rColor].ty += currentPerfMap[code].ty; colorVol[rColor].ly += currentPerfMap[code].ly;
       }

       let colLabels = []; let colGrowth = [];
       Object.entries(colorVol).filter(c=>c[1].ly > 0 && c[0] !== 'Other').forEach(c => {
          colLabels.push(c[0]); colGrowth.push(((c[1].ty - c[1].ly) / c[1].ly) * 100);
       });

       if(cColor) cColor.destroy();
       cColor = new Chart(document.getElementById('chart-color'), {
          type: 'line',
          data: { labels: colLabels, datasets: [{ label: 'YoY Growth %', data: colGrowth, borderColor: '#ec4899', backgroundColor: 'rgba(236, 72, 153, 0.2)', fill: true, tension: 0.3 }] },
          options: { 
             responsive: true, maintainAspectRatio: false, layout: { padding: { top: 25 } },
             plugins: { datalabels: { display: true, align: 'top', font: { weight: 'bold', size: 10 }, formatter: function(value) { return (value>0?'+':'') + value.toFixed(1) + '%'; } } }
          }
       });
    }

    function renderOpeTable(globalTotalTy) {
       let selectedNops = $('#ope-nop-filter').val() || [];
       let maxTy = Math.max(...Object.values(globalOpeData).map(o=>o.ty), 1); 
       let filteredOpe = Object.values(globalOpeData).filter(o => o.ty > (maxTy * 0.05) && o.ly > 0);
       
       if (selectedNops.length > 0) filteredOpe = filteredOpe.filter(o => selectedNops.includes(o.nop));

       let scoredOpe = filteredOpe.map(o => {
          let trueG = ((o.ty - o.ly) / o.ly) * 100; 
          let cappedG = trueG > 500 ? 500 : trueG; 
          let volScore = (o.ty / maxTy) * 100;
          o.score = (cappedG * 0.6) + (volScore * 0.4);
          o.growth = trueG; // Uncapped Exact Growth Value for display
          o.share = globalTotalTy > 0 ? (o.ty / globalTotalTy) * 100 : 0;
          return o;
       }).sort((a,b) => b.score - a.score).slice(0,5);

       let tbody = document.getElementById('reco-body'); tbody.innerHTML = '';
       if(scoredOpe.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="text-center text-gray-500 py-4">Insufficient historical data to calculate YoY momentum algorithm.</td></tr>';
       } else {
          scoredOpe.forEach(o => {
             let allColStr = [...o.allColors].join('; ');
             tbody.innerHTML += `<tr>
                <td class="font-bold text-gray-900">${o.nop}</td>
                <td class="font-semibold text-gray-800">${o.gen}</td>
                <td class="font-semibold text-gray-800">${o.col}</td>
                <td class="text-xs text-gray-500 capitalize max-w-xs truncate" style="white-space: normal;">${allColStr}</td>
                <td class="font-semibold text-blue-600">${o.prc}</td>
                <td class="font-bold text-gray-800">${o.share.toFixed(2)}%</td>
                <td class="text-gray-700 text-xs italic">Strong momentum: <span class="font-bold text-green-600">+${o.growth.toFixed(1)}% YoY</span> in this exact Gender/Price/Color segment. High priority for development.</td>
             </tr>`;
          });
       }
    }

    $('#color-nop-filter').on('change', renderColorChart);
    $('#ope-nop-filter').on('change', () => { renderOpeTable(Object.values(globalOpeData).reduce((s,o)=>s+o.ty,0)); });
  </script>
</body>
</html>
