      document.getElementById('card-mkpl').innerText = preCard + fmt.format(totMKPL); document.getElementById('grow-mkpl').innerHTML = showGrowth ? "Growth LY: " + calcGrowth(totMKPL, totMKPL_LY) : "&nbsp;";

      // 3. Offer Live Tab Update
      offerDataTable.clear();
      let m_myn=0, m_any=0, q_bz=0, q_any=0, q_denom=0;

      fMaster.forEach(m => {
