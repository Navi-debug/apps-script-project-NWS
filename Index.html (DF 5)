    function buildGlobalDropdowns() {
      const keys = ['sec', 'dep', 'sub', 'p1', 'abc', 'p2', 'dsm'];
      
      const applyCascading = () => {
        if(isRebuildingGlobal) return;
        isRebuildingGlobal = true;

        let fData = globalMasterData.filter(m => {
          if(gFilters.sec.length && !gFilters.sec.includes(m.sector)) return false;
          if(gFilters.dep.length && !gFilters.dep.includes(m.dept)) return false;
          if(gFilters.sub.length && !gFilters.sub.includes(m.subdept)) return false;
          if(gFilters.p1.length && !gFilters.p1.includes(m.family)) return false;
          if(gFilters.abc.length && !gFilters.abc.includes(m.codeAbc)) return false;
          if(gFilters.p2.length && !gFilters.p2.includes(m.prod2)) return false;
          if(gFilters.dsm.length && !gFilters.dsm.includes(m.dsm)) return false;
          if(isNewFiltered && !m.isNew) return false;
          return true;
        });

        keys.forEach(k => {
          if(gFilters[k].length === 0) { 
            let sel = $('#g-flt-' + k);
            sel.empty();
            let uniqueVals = [...new Set(fData.map(m => {
              if(k==='sec') return m.sector; if(k==='dep') return m.dept; if(k==='sub') return m.subdept;
              if(k==='p1') return m.family; if(k==='abc') return m.codeAbc; if(k==='p2') return m.prod2; return m.dsm;
            }))].filter(v => v && v!=='-').sort();
            uniqueVals.forEach(v => sel.append(new Option(v,v,false,false)));
            sel.trigger('change.select2');
          }
        });

        isRebuildingGlobal = false;
        applyAllViews();
        if($('#insights').hasClass('active')) updateInsightsView();
      };

      const initFlt = (id, key, propMap) => {
        let sel = $('#'+id);
        let u = [...new Set(globalMasterData.map(m => m[propMap]))].filter(v=>v && v!=='-').sort();
        u.forEach(v => sel.append(new Option(v,v,false,false)));
        sel.select2({placeholder:"All", allowClear:true, closeOnSelect:false, templateResult:formatCb});
        sel.on('change', function() { gFilters[key] = $(this).val() || []; applyCascading(); });
      };

      initFlt('g-flt-sec','sec','sector'); initFlt('g-flt-dep','dep','dept'); initFlt('g-flt-sub','sub','subdept');
      initFlt('g-flt-p1','p1','family'); initFlt('g-flt-abc','abc','codeAbc'); initFlt('g-flt-p2','p2','prod2'); initFlt('g-flt-dsm','dsm','dsm');

      $('#btn-global-reset').on('click', function() {
        $('#global-search').val('');
        masterDataTable.search('').draw(); perfDataTable.search('').draw(); offerDataTable.search('').draw();
        $('.g-flt').val(null).trigger('change.select2');
        $('.o-flt').val(''); 
        gFilters = {sec:[], dep:[], sub:[], p1:[], abc:[], p2:[], dsm:[]};
        if(isNewFiltered) { isNewFiltered=false; $('#btn-filter-new').removeClass('bg-blue-600 text-white').addClass('bg-gray-100 text-gray-700').text('🎯 Filter NEW'); }
        applyCascading();
      });

      $('#btn-filter-new').on('click', function() {
        isNewFiltered = !isNewFiltered;
        if(isNewFiltered) $(this).removeClass('bg-gray-100 text-gray-700').addClass('bg-blue-600 text-white').text('🎯 Clear NEW Filter');
        else $(this).removeClass('bg-blue-600 text-white').addClass('bg-gray-100 text-gray-700').text('🎯 Filter NEW');
        applyCascading();
      });
    }

    const checkGlobalFlt = (m) => {
      if(gFilters.sec.length && !gFilters.sec.includes(m.sector)) return false;
      if(gFilters.dep.length && !gFilters.dep.includes(m.dept)) return false;
      if(gFilters.sub.length && !gFilters.sub.includes(m.subdept)) return false;
      if(gFilters.p1.length && !gFilters.p1.includes(m.family)) return false;
