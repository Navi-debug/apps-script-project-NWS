const SECONDARY_WORKBOOK_ID = ''; 

function doGet() {
  return HtmlService.createTemplateFromFile('Index')
    .evaluate()
    .setTitle('Decathlon NWS Dashboard')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function getDashboardData() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const secondarySS = SECONDARY_WORKBOOK_ID ? SpreadsheetApp.openById(SECONDARY_WORKBOOK_ID) : ss;

  const models = {}; 
  const perfModels = {};
  let activeModelsCount = 0;
  const secondLifeRegex = /2nd\s*life/i; 

  // ==========================================
  // 1. MASTER DATABASE SPINE
  // ==========================================
  const lsSheet = ss.getSheetByName('LS1,2 Models');
  if (lsSheet) {
    const lsData = lsSheet.getDataRange().getValues();
    const codeRegex = /^\d{7}$/; 

    for (let i = 2; i < lsData.length; i++) { 
      let val1 = String(lsData[i][12]).trim(); 
      let mName1 = String(lsData[i][13] || '').trim();
      
      if (codeRegex.test(val1) && !models[val1] && !secondLifeRegex.test(mName1)) {
        models[val1] = { 
          isNew: false, code: val1, mName: mName1, nop: String(lsData[i][9] || '').trim(),    
          sector: String(lsData[i][2] || '').trim(), dept: String(lsData[i][3] || '').trim(),   
          subdept: String(lsData[i][2] || '').trim(), dsm: String(lsData[i][4] || '').trim(),    
          codeAbc: String(lsData[i][6] || '').trim(), isQcTarget: false 
        };
        activeModelsCount++;
      }
      
      let newCode = null;
      for (let c = 18; c < lsData[i].length; c++) {
        let testVal = String(lsData[i][c]).trim();
        if (codeRegex.test(testVal)) { newCode = testVal; break; }
      }

      if (newCode && !models[newCode]) {
        // FIX: Extracting New Model Name strictly from Column AC (Index 28)
        let mName2 = String(lsData[i][28] || '').trim();
        if (!secondLifeRegex.test(mName2)) {
          models[newCode] = { 
            isNew: true, code: newCode, mName: mName2, nop: String(lsData[i][9+18] || '').trim(),
            sector: String(lsData[i][19] || '').trim(), dept: String(lsData[i][20] || '').trim(),   
            subdept: String(lsData[i][19] || '').trim(), dsm: String(lsData[i][21] || '').trim(),    
            codeAbc: String(lsData[i][22] || '').trim(), isQcTarget: false 
          };
        }
      }
    }
  }

  const mpSheet = secondarySS.getSheetByName('MP Offer') || ss.getSheetByName('MP Offer');
  if (mpSheet) {
    const mpData = mpSheet.getDataRange().getValues();
    for(let i=1; i<mpData.length; i++) {
      let mCode = String(mpData[i][0]).trim();
      if(models[mCode]) {
        models[mCode].mpPrice = mpData[i][6]; 
        models[mCode].fallbackGender = String(mpData[i][7] || ''); 
      }
    }
  }

  const attrSheet = secondarySS.getSheetByName('Attribute Dump') || ss.getSheetByName('Attribute Dump');
  if (attrSheet) {
    const attrData = attrSheet.getDataRange().getValues();
    for(let i=1; i<attrData.length; i++) {
      let mCode = String(attrData[i][1]).trim(); 
      if(models[mCode]) {
        let primaryNop = String(attrData[i][6]).trim(); 
        if(primaryNop) models[mCode].nop = primaryNop; 
        models[mCode].gender = String(attrData[i][12] || ''); 
        models[mCode].sportpractice = String(attrData[i][13] || ''); 
        models[mCode].onlineSuggestedName = String(attrData[i][7] || ''); 
        let colorMatch = String(attrData[i][14] || '').match(/"bcdHexaLabel"\s*:\s*"([^"]+)"/i);
        models[mCode].color = colorMatch ? colorMatch[1] : ''; 
      }
    }
  }

  for (let key in models) {
    let g = models[key].gender || models[key].fallbackGender || '';
    if (g.toUpperCase().includes('MENS + UNISEX') || g.toUpperCase().includes('MENS+UNISEX')) g = 'No Gender';
    models[key].finalGender = g;
  }

  // ==========================================
  // 2. NWS PERFORMANCE ENGINE (MATRIX PARSER)
  // ==========================================
  
  // A. Fetch QC Sales & Bucket by Year/Week
  const qcSalesSheet = ss.getSheetByName('QC Sales (Sell in - Sales)');
  const qcWeekly = {}; 
  if (qcSalesSheet) {
    const qcsData = qcSalesSheet.getDataRange().getValues();
    const qcsHeaders = qcsData[0];
    let mIdx = qcsHeaders.indexOf('Model');
    let dIdx = qcsHeaders.indexOf('Invoice date');
    let qIdx = qcsHeaders.indexOf('Ordered Qty');
    let vIdx = qcsHeaders.indexOf('Total');

    if(mIdx > -1 && dIdx > -1) {
      for(let i=1; i<qcsData.length; i++) {
        let mCode = String(qcsData[i][mIdx]).trim();
        let dateObj = new Date(qcsData[i][dIdx]);
        if(isNaN(dateObj)) continue;
        
        let yw = getISOWeekAndYear(dateObj);
        if(!qcWeekly[mCode]) qcWeekly[mCode] = {};
        if(!qcWeekly[mCode][yw.year]) qcWeekly[mCode][yw.year] = {};
        if(!qcWeekly[mCode][yw.year][yw.week]) qcWeekly[mCode][yw.year][yw.week] = { qty: 0, val: 0 };
        
        qcWeekly[mCode][yw.year][yw.week].qty += (Number(qcsData[i][qIdx]) || 0);
        qcWeekly[mCode][yw.year][yw.week].val += (Number(qcsData[i][vIdx]) || 0);
      }
    }
  }

  // B. Parse Main Sales (Handling Merged Pivot Headers)
  const mainSalesSheet = ss.getSheetByName('B2B + QC + MKPL Sales');
  if (mainSalesSheet) {
    const msData = mainSalesSheet.getDataRange().getValues();
    
    let rChan = -1, rYear = -1, rMonth = -1, rWeek = -1;
    for (let r = 0; r < 10 && r < msData.length; r++) {
      let rowStr = msData[r].join(' ').toLowerCase();
      if (rowStr.includes('distribution channel')) rChan = r;
      if (rowStr.includes('calendar year') && !rowStr.includes('year/w')) rYear = r;
      if (rowStr.includes('calendar month')) rMonth = r;
      if (rowStr.includes('calendar year/w')) rWeek = r;
    }

    if (rChan !== -1 && rWeek !== -1) {
      let dataStartCol = -1;
      for (let c = 0; c < msData[rWeek].length; c++) {
        if (/^\d{1,2}\.\d{4}$/.test(String(msData[rWeek][c]).trim())) { dataStartCol = c; break; }
      }

      let codeCol = 8, nameCol = 9, keyFigCol = 11; 
      let firstDataRow = msData[rWeek + 1];
      if (firstDataRow) {
         for (let c = 0; c < dataStartCol; c++) {
           let val = String(firstDataRow[c]).trim();
           if (/^\d{7}$/.test(val)) codeCol = c;
           else if (val.includes('Sales Value') || val.includes('Sales Quantity') || val.includes('Sales Margin')) keyFigCol = c;
         }
         nameCol = codeCol + 1; 
      }

      // Fill-Right Logic for Merged Headers
      let colsMeta = [];
      let maxWeek26 = 0;
      let curChan = '', curYear = '', curMonth = '';

      for (let c = dataStartCol; c < msData[rWeek].length; c++) {
        if (msData[rChan][c]) curChan = String(msData[rChan][c]).trim();
        if (msData[rYear][c]) curYear = String(msData[rYear][c]).trim();
        if (msData[rMonth][c]) curMonth = String(msData[rMonth][c]).trim();

        let weekRaw = String(msData[rWeek][c]).trim();
        if (!weekRaw) continue;

        let w = parseInt(weekRaw.split('.')[0], 10);
        let y = parseInt(curYear, 10);
        let m = parseInt(curMonth, 10);

        if (y === 2026 && w > maxWeek26) maxWeek26 = w;
        colsMeta[c] = { channel: curChan, year: y, month: m, week: w };
      }

      // Aggregate Data Structure
      for (let r = rWeek + 1; r < msData.length; r++) {
        let row = msData[r];
        let mCode = String(row[codeCol]).trim();
        let mName = String(row[nameCol]).trim();
        let keyFig = String(row[keyFigCol]).trim();

        if (!mCode || secondLifeRegex.test(mName)) continue;

        if (!perfModels[mCode]) {
          let baseMet = { mkpl26:0, mkpl25:0, qc26:0, qc25:0, b2b26:0, b2b25:0 };
          perfModels[mCode] = { 
            code: mCode, name: mName,
            ytd: { val: {...baseMet}, qty: {...baseMet}, mar: {...baseMet} },
            months: {}, weeks: {}
          };
          for(let tm=1; tm<=12; tm++) perfModels[mCode].months[tm] = { val: {...baseMet}, qty: {...baseMet}, mar: {...baseMet} };
          for(let tw=1; tw<=52; tw++) perfModels[mCode].weeks[tw] = { val: {...baseMet}, qty: {...baseMet}, mar: {...baseMet} };
        }

        let metric = 'val';
        if (keyFig.includes('Quantity')) metric = 'qty';
        else if (keyFig.includes('Margin')) metric = 'mar';

        let rowQcApplied = {}; 

        for (let c = dataStartCol; c < row.length; c++) {
          let meta = colsMeta[c];
          if (!meta) continue;

          let val = Number(row[c]) || 0;
          if (val === 0 && metric !== 'qty') continue; 

          let yrKey = meta.year === 2026 ? '26' : (meta.year === 2025 ? '25' : null);
          if (!yrKey) continue;

          let isMkpl = meta.channel.toLowerCase().includes('marketplace');
          let isOthers = meta.channel.toLowerCase().includes('sales with others');

          let mkplVal = isMkpl ? val : 0;
          let b2bVal = 0, qcVal = 0;

          if (isOthers) {
             let qcKey = meta.year + '_' + meta.week;
             if (!rowQcApplied[qcKey] && (metric === 'val' || metric === 'qty')) {
                if (qcWeekly[mCode] && qcWeekly[mCode][meta.year] && qcWeekly[mCode][meta.year][meta.week]) {
                   qcVal = (metric === 'val') ? qcWeekly[mCode][meta.year][meta.week].val : qcWeekly[mCode][meta.year][meta.week].qty;
                }
                rowQcApplied[qcKey] = true; 
             }
             if (qcVal > val) qcVal = val; 
             b2bVal = val - qcVal;
          }

          let mObj = perfModels[mCode];

          // 1. YTD Aggregation
          if (meta.week <= maxWeek26) {
             if (isMkpl) mObj.ytd[metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.ytd[metric]['qc'+yrKey] += qcVal; mObj.ytd[metric]['b2b'+yrKey] += b2bVal; }
          }
          // 2. Month Aggregation
          if (meta.month >= 1 && meta.month <= 12) {
             if (isMkpl) mObj.months[meta.month][metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.months[meta.month][metric]['qc'+yrKey] += qcVal; mObj.months[meta.month][metric]['b2b'+yrKey] += b2bVal; }
          }
          // 3. Week Aggregation
          if (meta.week >= 1 && meta.week <= 52) {
             if (isMkpl) mObj.weeks[meta.week][metric]['mkpl'+yrKey] += mkplVal;
             if (isOthers) { mObj.weeks[meta.week][metric]['qc'+yrKey] += qcVal; mObj.weeks[meta.week][metric]['b2b'+yrKey] += b2bVal; }
          }
        }
      }
    }
  }

  for (let key in models) {
    if (secondLifeRegex.test(models[key].mName)) delete models[key];
  }

  const masterArray = Object.keys(models).map(k => models[k]);
  const perfArray = Object.keys(perfModels).map(k => perfModels[k]);

  return { masterData: masterArray, performanceData: perfArray, totalTracked: masterArray.length, timestamp: new Date().toLocaleString() };
}

function getISOWeekAndYear(date) {
  const d = new Date(date.getTime());
  d.setHours(0,0,0,0);
  d.setDate(d.getDate() + 4 - (d.getDay() || 7));
  const yearStart = new Date(d.getFullYear(),0,1);
  const week = Math.ceil((((d - yearStart) / 86400000) + 1)/7);
  return { year: d.getFullYear(), week: week };
}
