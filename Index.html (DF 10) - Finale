    function recalculateLiveKpis() {
      let m_myn=0, m_any=0, q_bz=0, q_any=0, q_denom=0;
      let fOffer = globalMasterData.filter(m => checkGlobalFlt(m) && !m.isDiscontinued);

      fOffer.forEach(m => {
        let my = String(m.myntraStatus).trim().toUpperCase(), aj = String(m.ajioStatus).trim().toUpperCase(), ta = String(m.tataCliqStatus).trim().toUpperCase();
        let isM = (my === 'LIVE' || my === 'Y' || my === 'YES' || my === 'TRUE'); 
        let isA = (aj === 'LIVE' || aj === 'Y' || aj === 'YES' || aj === 'TRUE');
        let isT = (ta === 'LIVE' || ta === 'Y' || ta === 'YES' || ta === 'TRUE');
        
        let bl = String(m.blinkit).trim().toUpperCase(), ze = String(m.zepto).trim().toUpperCase(), sw = String(m.swiggy).trim().toUpperCase();
        let isB = (bl === 'Y' || bl === 'LIVE' || bl === 'YES' || bl === 'TRUE');
        let isZ = (ze === 'Y' || ze === 'LIVE' || ze === 'YES' || ze === 'TRUE');
        let isS = (sw === 'Y' || sw === 'LIVE' || sw === 'YES' || sw === 'TRUE');
        
        if(isM) m_myn++;
        if(isM || isA || isT) m_any++;
        
        let isQcLiveAny = (isB || isZ || isS);
        if(m.isQcTarget || isQcLiveAny) {
           q_denom++;
           if(isB || isZ) q_bz++;
           if(isQcLiveAny) q_any++;
        }
      });

      let mTotal = fOffer.length || 1; 
      let qTotal = q_denom || 1;
      document.getElementById('kpi-m-myn').innerText = Math.round((m_myn/mTotal)*100) + '%';
      document.getElementById('kpi-m-any').innerText = Math.round((m_any/mTotal)*100) + '%';
      document.getElementById('kpi-q-bz').innerText = Math.round((q_bz/qTotal)*100) + '%';
      document.getElementById('kpi-q-any').innerText = Math.round((q_any/qTotal)*100) + '%';
    }

