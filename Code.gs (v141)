  let htmlFile = validPages.includes(page) ? page : 'Piloting';
  
  const pageTitles = {
    'Piloting': 'Macro Piloting',
    'ModelSummary': 'Model Summary',
    'CityStore': 'City & Store',
    'GridSize': 'Grid Size',
    'ShortageCorrection': 'Shortage Correction'
  };
