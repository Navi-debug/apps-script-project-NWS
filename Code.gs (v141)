// THE EXPORT ENGINE
// ==========================================
function executeExport(tabName, payloadStr, overwriteFlag, logDetails) {
  const TARGET_WORKBOOK_ID = '172e3TY0zlE9bhw0oU9KLoCgQtaAKpJrvCX8kMGQLlhk';
  let targetSS;
  try { 
    targetSS = SpreadsheetApp.openById(TARGET_WORKBOOK_ID); 
  } catch(e) { 
    throw new Error("Cannot access target workbook. Please ensure permissions are granted."); 
  }

  let sheet = targetSS.getSheetByName(tabName);
  
  if (sheet && !overwriteFlag) return "EXISTS";

  if (!sheet) {
    sheet = targetSS.insertSheet(tabName);
  } else {
    sheet.clear();
  }

  let data = JSON.parse(payloadStr);
  if (data.length > 0) {
    sheet.getRange(1, 1, 1, data[0].length).setValues([data[0]])
         .setBackground('#1e293b').setFontColor('#ffffff').setFontWeight('bold');
         
    if (data.length > 1) {
      sheet.getRange(2, 1, data.length - 1, data[0].length).setValues(data.slice(1));
    }
    sheet.autoResizeColumns(1, 8); 
  }

  // --- Main Log Tracker ---
  if (logDetails) {
    let logSheet = targetSS.getSheetByName('Main Log');
    if (!logSheet) {
      logSheet = targetSS.insertSheet('Main Log');
      logSheet.getRange(1, 1, 1, 5).setValues([['Timestamp', 'User Email', 'Source Dashboard', 'Target Tab', 'Export Parameters']])
              .setBackground('#0f172a').setFontColor('#ffffff').setFontWeight('bold');
      logSheet.autoResizeColumns(1, 5);
    }
    
    let userEmail = 'Unknown User';
    try { userEmail = Session.getActiveUser().getEmail(); } catch(e) {}
    
    logSheet.appendRow([new Date(), userEmail, logDetails.source, tabName, logDetails.params]);
  }

  return "Export Successful!";
}

// ==========================================
// AUTOMATED SAP/AFO EXCEL MASTER CLONE ENGINE (V6.1 - SURGICAL PRS SHIFT)
// ==========================================
function importAFOData() {
  try {
    const excelFileName = "Sales & Forecast Universe.xlsx"; 
    
    const files = DriveApp.getFilesByName(excelFileName);
    if (!files.hasNext()) throw new Error(`Could not find an Excel file named "${excelFileName}" in your Google Drive.`);
    
    const excelFile = files.next();
    const blob = excelFile.getBlob();

    // Convert Excel to Google Sheets format
    const fileResource = { name: "TEMP_AFO_IMPORT", mimeType: MimeType.GOOGLE_SHEETS };
    const tempFile = Drive.Files.create(fileResource, blob); 

    const tempSS = SpreadsheetApp.openById(tempFile.id);
    const tempSheets = tempSS.getSheets();

    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let updatedTabs = [];

    // Master Clone Loop
    tempSheets.forEach(tSheet => {
      let tName = tSheet.getName();
      let targetSheet = ss.getSheetByName(tName);
      
      if (targetSheet) {
        let rawLastRow = tSheet.getLastRow();
        let rawLastCol = tSheet.getLastColumn();
        
        // --- THE SURGICAL SHIFT EXCEPTION ---
        // If it is PRS, start at Column A (1). For all others, protect Col A and start at Col B (2).
        let startCol = (tName === 'PRS (Channel-Item)') ? 1 : 2;
        
        // Ensure there is data beyond just Row 1
        if (rawLastRow > 1 && rawLastCol >= startCol) {
          
          // 1. GHOST RADAR: Find the TRUE Column Width
          let trueLastCol = startCol; 
          let sampleRows = Math.min(20, rawLastRow); 
          let sampleData = tSheet.getRange(1, 1, sampleRows, rawLastCol).getValues();
          
          for (let r = 0; r < sampleRows; r++) {
            for (let c = rawLastCol - 1; c >= startCol - 1; c--) { 
              if (sampleData[r][c] !== null && String(sampleData[r][c]).trim() !== "") {
                trueLastCol = Math.max(trueLastCol, c + 1);
                break;
              }
            }
          }
          
          let numColsToFetch = trueLastCol - startCol + 1; 

          // 2. AUTO-EXPAND COLUMNS
          let currentMaxCols = targetSheet.getMaxColumns();
          if (currentMaxCols < trueLastCol) {
            targetSheet.insertColumnsAfter(currentMaxCols, trueLastCol - currentMaxCols + 2);
          }

          // 3. PROTECTED CLEAR (Wipe from Row 2 downwards, respecting startCol)
          let currentMaxRows = targetSheet.getMaxRows();
          currentMaxCols = targetSheet.getMaxColumns(); 
          
          if (currentMaxRows > 1 && currentMaxCols >= startCol) {
             targetSheet.getRange(2, startCol, currentMaxRows - 1, currentMaxCols - startCol + 1).clearContent();
          }

          // 4. CHUNKED 1:1 DATA TRANSFER & GHOST ROW EJECTOR
          let chunkSize = 5000; 
          let actualLastRow = 1;

          // Start loop at Row 2
          for (let i = 2; i <= rawLastRow; i += chunkSize) {
            let rowsToFetch = Math.min(chunkSize, rawLastRow - i + 1);
            
            // Fetch exactly from Row i, dynamically starting at startCol
            let chunkData = tSheet.getRange(i, startCol, rowsToFetch, numColsToFetch).getValues();
            
            // Ghost Ejector: Check if this chunk is empty
            let isChunkEmpty = true;
            for (let r = 0; r < rowsToFetch; r++) {
               if (String(chunkData[r][0] || "").trim() !== "" || 
                  (numColsToFetch > 1 && String(chunkData[r][1] || "").trim() !== "")) {
                  isChunkEmpty = false;
                  break;
               }
            }
            
            if (isChunkEmpty) {
               break; // EJECT! Hit the AFO formatting void.
            }
            
            // Auto-Expand Rows dynamically
            let reqRowsToPaste = i + rowsToFetch - 1;
            if (targetSheet.getMaxRows() < reqRowsToPaste) {
               targetSheet.insertRowsAfter(targetSheet.getMaxRows(), Math.max(chunkSize, reqRowsToPaste - targetSheet.getMaxRows() + 10));
            }

            // Paste EXACTLY into Row i, dynamically starting at startCol
            targetSheet.getRange(i, startCol, rowsToFetch, numColsToFetch).setValues(chunkData);
            actualLastRow = reqRowsToPaste;
          }
          
          // 5. THE GUILLOTINE: Auto-Trim Excess Blank Space
          let finalMaxRows = targetSheet.getMaxRows();
          let finalMaxCols = targetSheet.getMaxColumns();

          // Trim rows safely
          if (finalMaxRows > actualLastRow) {
            let trimStartRow = Math.max(2, actualLastRow + 1);
            if (finalMaxRows >= trimStartRow) {
              targetSheet.deleteRows(trimStartRow, finalMaxRows - trimStartRow + 1);
            }
          }

          // Trim columns safely
          if (finalMaxCols > trueLastCol) {
            let trimStartCol = Math.max(startCol, trueLastCol + 1);
            if (finalMaxCols >= trimStartCol) {
              targetSheet.deleteColumns(trimStartCol, finalMaxCols - trimStartCol + 1);
            }
          }

          updatedTabs.push(tName);
        }
      }
    });

    // Clean up temporary conversion file
    DriveApp.getFileById(tempFile.id).setTrashed(true);
    return `AFO Clone Successful! Surgically aligned and perfectly trimmed ${updatedTabs.length} tabs.`;
    
  } catch (error) { 
    throw new Error("AFO Import Failed: " + error.message); 
  }
}

// ==========================================
// SHORTAGE CORRECTION INITIALIZATION
// ==========================================
function getShortageInitData() {
  try {
    // 1. Fetch the high-speed base Data Lake (History, Forecasts, Shortage, Store Counts)
    let baseDataStr = getGridSizeInitData();
    let baseData = JSON.parse(baseDataStr);
    
    // 2. Fetch the User Overrides & Settings
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const OVERRIDES_SHEET_NAME = (typeof CONFIG !== 'undefined' && CONFIG.SHEETS && CONFIG.SHEETS.OVERRIDES) ? CONFIG.SHEETS.OVERRIDES : '_SHORTAGE_OVERRIDES_';
    const overrideSheet = ss.getSheetByName(OVERRIDES_SHEET_NAME);
    
    let settingsMap = {};
    
    if (overrideSheet) {
      const data = overrideSheet.getDataRange().getValues();
      // data[0] is headers: ['CODE', 'TYPE', 'KEY', 'VALUE']
      for (let r = 1; r < data.length; r++) {
        let code = String(data[r][0]).trim().toUpperCase();
        let type = String(data[r][1]).trim().toUpperCase();
        let key = String(data[r][2]).trim(); // week (e.g. "14.2026") or "MODEL"
        let val = data[r][3];
        
        if (!code) continue;
        if (!settingsMap[code]) settingsMap[code] = { WEEKS: {} };
        
        // Route Model-Level Settings vs Week-Level Overrides
        if (key.toUpperCase() === 'MODEL') {
          if (type === 'SUBST') settingsMap[code].SUBST = val;
          if (type === 'MOD_X') settingsMap[code].MOD_X = val !== "" ? parseFloat(val) : null;
        } else {
          if (!settingsMap[code].WEEKS[key]) settingsMap[code].WEEKS[key] = {};
          
          if (type === 'CELL_TD') settingsMap[code].WEEKS[key].CELL_TD = val !== "" ? parseFloat(val) : null;
          if (type === 'CELL_X') settingsMap[code].WEEKS[key].CELL_X = val !== "" ? parseFloat(val) : null;
          if (type === 'EPHEMERIDE') settingsMap[code].WEEKS[key].EPHEMERIDE = String(val);
        }
      }
    }
    
    // 3. Merge and deploy to Frontend
    baseData.settings = settingsMap;
    return JSON.stringify(baseData);
    
  } catch (err) {
    throw new Error("Failed to load Shortage Overrides: " + err.message);
  }
}
