      .setTitle(activeTitle)
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

// ==========================================
// TOP LEVEL PILOTING FUNCTIONS
// ==========================================
function getPilotingInitData() {
  try {
    const localApp = SpreadsheetApp.getActiveSpreadsheet();
    const pastSalesSheet = localApp.getSheetByName(CONFIG.SHEETS.PAST_SALES_TOP);
    if (!pastSalesSheet) throw new Error("Top Level sheet not found.");
    
    const rawData = pastSalesSheet.getDataRange().getValues();
    if (rawData.length < 3) return JSON.stringify({ families: [], records: [] });

    const COL_FAMILY = 4, COL_CHANNEL = 5, COL_WEEKS_START = 7;
    let weekCols = {}, headerRowIndex = -1;

    for (let r = 0; r < Math.min(10, rawData.length); r++) {
      for (let c = COL_WEEKS_START; c < rawData[r].length; c++) {
        if (String(rawData[r][c]).match(/(\d+)\.(20\d\d)/)) { headerRowIndex = r; break; }
      }
      if (headerRowIndex !== -1) break;
    }
    if (headerRowIndex === -1) throw new Error("Could not find Week Headers.");

    let weekHeaders = rawData[headerRowIndex];
    for (let c = COL_WEEKS_START; c < weekHeaders.length; c++) {
      let match = String(weekHeaders[c]).trim().match(/(\d+)\.(20\d\d)/);
      if (match) weekCols[`${parseInt(match[1])}.${parseInt(match[2])}`] = c;
    }

    let processedRecords = [], uniqueFamilies = new Set();
    for (let r = headerRowIndex + 2; r < rawData.length; r++) { 
      let family = String(rawData[r][COL_FAMILY] || '').trim();
      let channel = String(rawData[r][COL_CHANNEL] || '').trim();
      if (!family) continue; 
      uniqueFamilies.add(family);
      
      let compressedRow = { f: family, c: channel, w: {} }, hasData = false;
      for (let key in weekCols) {
        let val = parseFloat(String(rawData[r][weekCols[key]] || '0').replace(/,/g, ''));
        if (val && val !== 0) { compressedRow.w[key] = val; hasData = true; }
      }
      if (hasData) processedRecords.push(compressedRow);
    }
    return JSON.stringify({ families: Array.from(uniqueFamilies).sort(), records: processedRecords });
  } catch (error) { throw new Error(error.message); }
}

function commitPilotingData(payloadStr) { return "Forecast committed successfully."; }

// ==========================================
// BOT LEVEL 3D DATA LAKE ENGINE (PRS)
// ==========================================
function initBotCache(ss) {
  let sheet = ss.getSheetByName(CONFIG.SHEETS.BOT_CACHE);
  if (!sheet) { sheet = ss.insertSheet(CONFIG.SHEETS.BOT_CACHE); sheet.hideSheet(); }
  return sheet;
}

function syncBotLevelData() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let mapType = {};
    const typSheet = ss.getSheetByName(CONFIG.SHEETS.TYPOLOGIES);
    if (typSheet) {
      const typData = typSheet.getDataRange().getValues();
      for (let r = 2; r < typData.length; r++) {
        let modCode = String(typData[r][1]).trim().toUpperCase();
        let modName = String(typData[r][2]).trim().toUpperCase();
        let typName = String(typData[r][3]).trim();
        if(typName) {
          if(modCode) mapType[modCode] = typName; 
          if(modName) mapType[modName] = typName; 
        }
      }
    }

    const botSheet = ss.getSheetByName(CONFIG.SHEETS.PAST_SALES_BOT);
    if(!botSheet) throw new Error("PRS (Channel-Item) sheet not found!");
    const botData = botSheet.getDataRange().getValues();
    
    if (botData.length < 4) throw new Error("PRS Sheet is missing data rows.");
    
    const rowMetrics = botData[1]; 
    const rowWeeks = botData[2];   
    const rowHeaders = botData[3]; 
    
    let map = { rng:-1, abc:-1, spt:-1, dep:-1, sdep:-1, ch:-1, nop:-1 };
    rowHeaders.forEach((h, i) => {
      let txt = String(h).toLowerCase().trim();
      let exactTxt = String(h).trim();
      if(txt.includes('assortment grade')) map.rng = i;
      if(txt.includes('code abc')) map.abc = i;
      if(txt.includes('sector')) map.spt = i;
      if(txt.includes('department') && !txt.includes('sub')) map.dep = i;
      if(txt.includes('subdepartment') || txt.includes('sub dept')) map.sdep = i;
      if(txt.includes('distribution channel')) map.ch = i;
      if(exactTxt === 'Merchandise Category (Prod2)') map.nop = i;
    });

    let weekCols = {};
    let currMetric = 'v'; 
    
    for (let c = 17; c < rowWeeks.length; c++) {
      let mTxt = String(rowMetrics[c]).toLowerCase();
      if(mTxt.includes('value')) currMetric = 'v';
      else if(mTxt.includes('quantity') || mTxt.includes('qty')) currMetric = 'q';
      else if(mTxt.includes('margin')) currMetric = 'm';

      let wkMatch = String(rowWeeks[c]).trim().match(/(\d+)\.(20\d\d)/);
      if (wkMatch) weekCols[c] = { w: `${parseInt(wkMatch[1])}.${parseInt(wkMatch[2])}`, m: currMetric };
    }

    let recordsMap = {};
    for (let r = 4; r < botData.length; r++) {
      let nop = map.nop > -1 ? String(botData[r][map.nop]).trim() : 'UNASSIGNED';
      
      let dsmCode = String(botData[r][8]).trim();
      let dsmName = String(botData[r][9]).trim();
      let modCode = String(botData[r][10]).trim();
      let modName = String(botData[r][11]).trim();
      let itmCode = String(botData[r][12]).trim();
      let itmName = String(botData[r][13]).trim();
      
      let famCode = String(botData[r][14] || "").trim();
      let famName = String(botData[r][15] || "").trim();
      let famFused = (famName && famCode) ? (famName + "::" + famCode) : (famName || famCode || 'UNASSIGNED');

      if (!modCode && !modName) continue; 

      let dsmCombined = dsmName + (dsmCode ? "::" + dsmCode : "");
      let modCombined = modName + (modCode ? "::" + modCode : "");
      let itmCombined = itmName + (itmCode ? "::" + itmCode : "");

      let rng = map.rng > -1 ? String(botData[r][map.rng]).trim() : '';
      let abc = map.abc > -1 ? String(botData[r][map.abc]).trim() : '';
      let spt = map.spt > -1 ? String(botData[r][map.spt]).trim() : '';
      let dep = map.dep > -1 ? String(botData[r][map.dep]).trim() : '';
      let sdep = map.sdep > -1 ? String(botData[r][map.sdep]).trim() : '';
      let ch = map.ch > -1 ? String(botData[r][map.ch]).trim() : 'Unassigned';
      
      let typ = mapType[modCode.toUpperCase()] || mapType[modName.toUpperCase()] || '';
      let grp = typ ? typ : (dsmCombined ? dsmCombined : 'NO TYPOLOGY OR DSM');

      let key = `${rng}|${abc}|${spt}|${dep}|${sdep}|${nop}|${dsmCombined}|${modCombined}|${itmCombined}|${famFused}|${ch}`;
      
      if(!recordsMap[key]) {
        recordsMap[key] = { rng, abc, spt, dep, sdep, nop, dsm: dsmCombined, mod: modCombined, itm: itmCombined, fam: famFused, typ, grp, ch, w: {} };
      }

      let rowRef = recordsMap[key].w;
      for (let c in weekCols) {
        let val = parseFloat(String(botData[r][c]).replace(/,/g, ''));
        if (val) {
          let wk = weekCols[c].w;
          let mType = weekCols[c].m;
          if(!rowRef[wk]) rowRef[wk] = {v:0, q:0, m:0};
          rowRef[wk][mType] += val;
        }
      }
    }

    let records = Object.values(recordsMap).filter(r => Object.keys(r.w).length > 0);
    let jsonString = JSON.stringify(records);
    let chunks = jsonString.match(/[\s\S]{1,45000}/g) || [];
    let cacheSheet = initBotCache(ss);
    cacheSheet.clear();
    let outData = chunks.map(c => [c]);
    if (outData.length > 0) cacheSheet.getRange(1, 1, outData.length, 1).setValues(outData);

    return "Data Lake Built Successfully.";
  } catch (err) { throw new Error("Sync Error: " + (err.message || String(err))); }
}

