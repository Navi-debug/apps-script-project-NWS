// CITY & STORE DATA LAKE ENGINE 
// ==========================================
function syncCityStoreData() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();

    let famMap = {};
    const prsSheet = ss.getSheetByName(CONFIG.SHEETS.PAST_SALES_BOT);
    if (prsSheet) {
      const prsData = prsSheet.getDataRange().getValues();
      
      if (prsData.length > 3) {
        let prsHeaders = prsData[3]; 
        let sptIdx = -1, depIdx = -1, sdepIdx = -1;
        
        prsHeaders.forEach((h, i) => {
          let txt = String(h).toLowerCase().trim();
          if(txt.includes('sector') || txt.includes('sport')) sptIdx = i;
          if(txt.includes('department') && !txt.includes('sub')) depIdx = i;
          if(txt.includes('subdepartment') || txt.includes('sub dept')) sdepIdx = i;
        });

        for (let r = 4; r < prsData.length; r++) {
          let famCode = String(prsData[r][14] || "").trim();
          if (famCode && !famMap[famCode]) {
            famMap[famCode] = {
              spt: sptIdx > -1 ? String(prsData[r][sptIdx]).trim() : 'UNASSIGNED',
              dep: depIdx > -1 ? String(prsData[r][depIdx]).trim() : 'UNASSIGNED',
              sdep: sdepIdx > -1 ? String(prsData[r][sdepIdx]).trim() : 'UNASSIGNED'
            };
          }
        }
      }
    }

    const csSheet = ss.getSheetByName(CONFIG.SHEETS.CITY_STORE);
    if(!csSheet) throw new Error("'City & Store' sheet not found!");
    const csData = csSheet.getDataRange().getValues();
    
    if (csData.length < 4) throw new Error("City & Store sheet appears empty.");
    
    let weekRowIdx = -1, metricRowIdx = -1;
    for (let i = 0; i < Math.min(6, csData.length); i++) {
      for (let j = 7; j < csData[i].length; j++) {
         if (String(csData[i][j]).match(/(\d+)\.(20\d\d)/)) { weekRowIdx = i; break; }
      }
      if (weekRowIdx > -1) break;
    }
    if (weekRowIdx === -1) throw new Error("Could not find Wk.Year headers in City & Store (e.g., 1.2025).");
    
    let possibleMetricRow1 = (weekRowIdx > 0) ? csData[weekRowIdx - 1] : [];
    let possibleMetricRow2 = (weekRowIdx < csData.length - 1) ? csData[weekRowIdx + 1] : [];
    let useRow = null;
    
    if (String(possibleMetricRow1[7]||'').toLowerCase().includes('val') || String(possibleMetricRow1[8]||'').toLowerCase().includes('qty')) {
        useRow = possibleMetricRow1; metricRowIdx = weekRowIdx - 1;
    } else if (String(possibleMetricRow2[7]||'').toLowerCase().includes('val') || String(possibleMetricRow2[8]||'').toLowerCase().includes('qty')) {
        useRow = possibleMetricRow2; metricRowIdx = weekRowIdx + 1;
    }

    let weekCols = {};
    let currMetric = 'v'; 
    for (let c = 7; c < csData[weekRowIdx].length; c++) {
      if (useRow && useRow[c]) {
         let mTxt = String(useRow[c]).toLowerCase();
         if (mTxt.includes('val')) currMetric = 'v';
         else if (mTxt.includes('qty') || mTxt.includes('quant')) currMetric = 'q';
         else if (mTxt.includes('margin')) currMetric = 'm';
      }
      let wkMatch = String(csData[weekRowIdx][c]).trim().match(/(\d+)\.(20\d\d)/);
      if (wkMatch) weekCols[c] = { w: `${parseInt(wkMatch[1])}.${parseInt(wkMatch[2])}`, m: currMetric };
    }

    let recordsMap = {};
    let startDataRow = Math.max(weekRowIdx, metricRowIdx) + 1;
    if (startDataRow < 4) startDataRow = 4;

    for (let r = startDataRow; r < csData.length; r++) {
      let state = String(csData[r][1] || '').trim();      
      let plant = String(csData[r][2] || '').trim();      
      let storeName = String(csData[r][3] || '').trim();  
      let famCode = String(csData[r][4] || '').trim();    
      let famName = String(csData[r][5] || '').trim();    

      if (!plant && !storeName) continue;

      let storeCombined = storeName + (plant ? "::" + plant : "");
      let famFused = famName + (famCode ? "::" + famCode : "");

      let hier = famMap[famCode] || { spt: 'UNASSIGNED', dep: 'UNASSIGNED', sdep: 'UNASSIGNED' };

      let key = `${state}|${storeCombined}|${famFused}`;
      if (!recordsMap[key]) {
        recordsMap[key] = {
          state: state, store: storeCombined, fam: famFused,
          spt: hier.spt, dep: hier.dep, sdep: hier.sdep,
          w: {}
        };
      }

      let rowRef = recordsMap[key].w;
      for (let c in weekCols) {
        let val = parseFloat(String(csData[r][c]).replace(/,/g, ''));
        if (val) {
          let wk = weekCols[c].w;
          let mType = weekCols[c].m;
          if(!rowRef[wk]) rowRef[wk] = {v:0, q:0, m:0};
          rowRef[wk][mType] += val;
        }
      }
    }

    let records = Object.values(recordsMap).filter(r => Object.keys(r.w).length > 0);
    let jsonString = JSON.stringify(records);
    let chunks = jsonString.match(/[\s\S]{1,45000}/g) || [];
    
    let cacheSheet = ss.getSheetByName(CONFIG.SHEETS.CITY_CACHE);
    if (!cacheSheet) { cacheSheet = ss.insertSheet(CONFIG.SHEETS.CITY_CACHE); cacheSheet.hideSheet(); }
    cacheSheet.clear();
    
    let outData = chunks.map(c => [c]);
    if (outData.length > 0) cacheSheet.getRange(1, 1, outData.length, 1).setValues(outData);

    return "City & Store Database Built Successfully.";
  } catch (err) { 
    throw new Error(err.message || String(err)); 
  }
}

