// ==========================================
// DATA LAKE ENGINE: GRID SIZE, SHORTAGE & FORECASTS
// ==========================================
function getGridSizeInitData() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  const BOT_SHEET_NAME = (typeof CONFIG !== 'undefined' && CONFIG.SHEETS && CONFIG.SHEETS.BOT_CACHE) ? CONFIG.SHEETS.BOT_CACHE : 'Bot Level Data';
  const FC_SHEET_NAME = (typeof CONFIG !== 'undefined' && CONFIG.SHEETS && CONFIG.SHEETS.FORECAST) ? CONFIG.SHEETS.FORECAST : 'Sales Forecasting';
  const SH_SHEET_NAME = (typeof CONFIG !== 'undefined' && CONFIG.SHEETS && CONFIG.SHEETS.SHORTAGE) ? CONFIG.SHEETS.SHORTAGE : 'Shortage';

  let historyStr = '[]';
  const cacheSheet = ss.getSheetByName(BOT_SHEET_NAME);
  if(cacheSheet && cacheSheet.getLastRow() > 0) {
    historyStr = cacheSheet.getRange(1, 1, cacheSheet.getLastRow(), 1).getValues().map(r => r[0]).join('');
  }

  // --- 1. THE FORECAST ENGINE (WEEK-ON-WEEK EXTRACTION) ---
  let forecastMap = {};
  const fcSheet = ss.getSheetByName(FC_SHEET_NAME);
  if (fcSheet) {
    const data = fcSheet.getDataRange().getValues();
    if (data.length > 4) {
      const headers = data[2]; // Row 3 contains Week headers
      
      let weekCols = {};
      // Scan from Column G (Index 6) onwards for Wk.Yr strings
      for (let c = 6; c < headers.length; c++) {
        let match = String(headers[c]).trim().match(/(\d+)\.(20\d\d)/);
        if (match) weekCols[c] = `${parseInt(match[1])}.${parseInt(match[2])}`;
      }

      for (let r = 4; r < data.length; r++) { // Data starts Row 5
        let mCode = String(data[r][1]).trim().toUpperCase(); // Col B
        let mName = String(data[r][2]).trim(); // Col C
        let iCode = String(data[r][3]).trim().toUpperCase(); // Col D
        let iName = String(data[r][4]).trim(); // Col E
        
        if (!mCode) continue;

        let mCombined = mName + (mCode ? "::" + mCode : "");
        let iCombined = iName + (iCode ? "::" + iCode : "");

        if (!forecastMap[mCode]) forecastMap[mCode] = { name: mCombined, total: 0, items: {} };
        if (!forecastMap[mCode].items[iCode]) forecastMap[mCode].items[iCode] = { name: iCombined, qty: 0, w: {} };
        
        // Accumulate Weekly Forecasts
        for (let c in weekCols) {
           let val = parseFloat(String(data[r][c]).replace(/,/g, '')) || 0;
           if (val > 0) {
               let wkStr = weekCols[c];
               forecastMap[mCode].items[iCode].w[wkStr] = val;
               forecastMap[mCode].items[iCode].qty += val;
               forecastMap[mCode].total += val;
           }
        }
      }
    }
  }

  // 2. Fetch Store Counts (Dynamic Horizontal Layout)
  let storeCounts = {};
  const scSheet = ss.getSheetByName('Store Count'); 
  if (scSheet) {
      let lr = scSheet.getLastRow();
      if (lr < 5) lr = 56; 
      
      function parseStoreBlock(rangeStr) {
          try {
              let data = scSheet.getRange(rangeStr).getValues();
              let map = {};
              for(let r = 2; r < data.length; r++) { 
                  let famCode = String(data[r][0]).trim();
                  if(!famCode || famCode.toLowerCase().includes('category')) continue;
                  
                  let c1 = parseFloat(data[r][2]) || 0; 
                  let c2 = parseFloat(data[r][3]) || 0; 
                  let c3 = parseFloat(data[r][4]) || 0; 
                  
                  map[famCode] = { '1': c1+c2+c3, '2': c2+c3, '3': c3 };
              }
              return map;
          } catch(e) { return {}; }
      }
      
      storeCounts['FW2026'] = parseStoreBlock('A3:G' + lr);
      storeCounts['SS2026'] = parseStoreBlock('I3:O' + lr);
      storeCounts['SS2025'] = parseStoreBlock('Q3:W' + lr);
      storeCounts['FW2025'] = parseStoreBlock('Y3:AE' + lr);
      storeCounts['SS2024'] = parseStoreBlock('AG3:AM' + lr);
      storeCounts['FW2024'] = parseStoreBlock('AO3:AU' + lr);
  }

  // 3. Fetch Shortage Map (.getDisplayValues() logic for decimals)
  let shortageMap = {};
  const shSheet = ss.getSheetByName(SH_SHEET_NAME);
  if (shSheet) {
    const shData = shSheet.getDataRange().getDisplayValues(); 
    if (shData.length > 3) {
      const rowHeaders = shData[2]; 
      let idxMod = -1, idxItm = -1;
      rowHeaders.forEach((h, i) => {
        let txt = String(h).toLowerCase().trim();
        if(txt.includes('generic article')) idxMod = i;
        if(txt.includes('material')) idxItm = i;
      });
      if(idxMod === -1) idxMod = 6; 
      if(idxItm === -1) idxItm = 8; 

      let wkCols = {};
      rowHeaders.forEach((w, i) => {
        let match = String(w).trim().match(/(\d+)\.(20\d\d)/);
        if (match) wkCols[i] = `${parseInt(match[1])}.${parseInt(match[2])}`;
      });

      for (let r = 3; r < shData.length; r++) { 
        let itmCode = String(shData[r][idxItm]).trim().toUpperCase();
        let modCode = String(shData[r][idxMod]).trim().toUpperCase();
        let targetCode = (itmCode === 'RESULT' || itmCode === '') ? modCode : itmCode;
        if (!targetCode) continue;

        if (!shortageMap[targetCode]) shortageMap[targetCode] = {};

        for (let c in wkCols) {
          let sVal = String(shData[r][c]).trim().replace('%', '');
          if (sVal !== "") { 
            let numVal = parseFloat(sVal);
            if (!isNaN(numVal)) {
              shortageMap[targetCode][wkCols[c]] = numVal / 100;
            }
          }
        }
      }
    }
  }

  return JSON.stringify({ history: historyStr, forecast: forecastMap, storeCounts: storeCounts, shortage: shortageMap });
}
function saveShortageSettings(payloadStr) {
  const payload = JSON.parse(payloadStr);
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName(CONFIG.SHEETS.OVERRIDES);
  if (!sheet) {
    sheet = ss.insertSheet(CONFIG.SHEETS.OVERRIDES);
    sheet.hideSheet();
    sheet.appendRow(['CODE', 'TYPE', 'KEY', 'VALUE']);
  }
  
  const data = sheet.getDataRange().getValues();
  let found = false;
  
  for (let r = 1; r < data.length; r++) {
    if (String(data[r][0]).toUpperCase() === String(payload.code).toUpperCase() && 
        String(data[r][1]).toUpperCase() === String(payload.type).toUpperCase() && 
        String(data[r][2]).toUpperCase() === String(payload.key).toUpperCase()) {
       
       if (payload.value === null || payload.value === "") {
          sheet.deleteRow(r + 1); 
       } else {
          sheet.getRange(r+1, 4).setValue(payload.value);
       }
       found = true;
       break;
    }
  }
  if (!found && payload.value !== null && payload.value !== "") {
    sheet.appendRow([String(payload.code).toUpperCase(), String(payload.type).toUpperCase(), String(payload.key).toUpperCase(), payload.value]);
  }
  return "Saved";
}

function fetchExternalTrueDemand(sheetName) {
  try {
    const SOURCE_WORKBOOK_ID = '1d4xg8fT5CNaWFocOgXqxag_e161oWaXgKnFG7HInQV8';
    let ss;
    try { ss = SpreadsheetApp.openById(SOURCE_WORKBOOK_ID); } 
    catch(e) { throw new Error("Permission denied to external workbook."); }
    
    let sheet = ss.getSheetByName(sheetName);
    if (!sheet) throw new Error(`Sheet '${sheetName}' not found.`);
    
    const data = sheet.getDataRange().getValues();
    if (data.length < 2) return "{}";
    
    const headers = data[0];
    let wkCols = {};
    for (let c = 8; c < headers.length; c++) {
      let match = String(headers[c]).match(/W(\d+)\.(20\d\d)_TrueDemand/i);
      if (match) {
        wkCols[c] = `${parseInt(match[1])}.${parseInt(match[2])}`;
      }
    }
    
    let tdMap = {};
    for (let r = 1; r < data.length; r++) {
      let mCode = String(data[r][0]).trim().toUpperCase();
      let iCode = String(data[r][2]).trim().toUpperCase();
      if (!mCode) continue;
      
      if (!tdMap[mCode]) tdMap[mCode] = {};
      
      for (let c in wkCols) {
        let val = parseFloat(data[r][c]);
        if (!isNaN(val) && val > 0) {
           let targetKey = iCode ? iCode : mCode; 
           if(!tdMap[mCode][targetKey]) tdMap[mCode][targetKey] = {};
           tdMap[mCode][targetKey][wkCols[c]] = val;
        }
      }
    }
    return JSON.stringify(tdMap);
  } catch (err) {
    throw new Error(err.message || String(err));
  }
}

